---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>لوحة التحكم - وصله</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/wslha.css">
  <style>
    body { padding: 0; background: #F8FAFC; }
    .admin-layout { display: flex; min-height: 100vh; }
    /* Sidebar */
    .sidebar { width: 260px; background: linear-gradient(180deg, #0F172A 0%, #1E293B 100%); position: fixed; top: 0; right: 0; bottom: 0; overflow-y: auto; z-index: 50; }
    .sidebar-logo { padding: 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .logo-app { font-size: 28px; font-weight: 900; color: white; }
    .logo-sub { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 4px; }
    .sidebar-user { padding: 16px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; gap: 10px; }
    .user-av { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #1D4ED8, #3B82F6); display: flex; align-items: center; justify-content: center; font-size: 16px; color: white; font-weight: 800; flex-shrink: 0; }
    .user-av-name { font-size: 14px; font-weight: 700; color: white; }
    .user-av-role { font-size: 11px; color: rgba(255,255,255,0.4); }
    .sidebar-section { padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .sidebar-section-title { padding: 4px 20px 10px; font-size: 10px; font-weight: 800; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 1.5px; }
    .sidebar-nav-item { display: flex; align-items: center; gap: 12px; padding: 12px 20px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 14px; font-weight: 600; transition: all 0.3s; cursor: pointer; position: relative; }
    .sidebar-nav-item:hover, .sidebar-nav-item.active { color: white; background: rgba(255,255,255,0.08); }
    .sidebar-nav-item.active::before { content: ''; position: absolute; right: 0; top: 4px; bottom: 4px; width: 3px; background: #3B82F6; border-radius: 3px 0 0 3px; }
    .sidebar-nav-icon { font-size: 18px; width: 22px; text-align: center; }
    .nav-badge { background: #EF4444; color: white; padding: 2px 7px; border-radius: 10px; font-size: 10px; font-weight: 700; margin-right: auto; }
    .nav-badge.green { background: #10B981; }
    /* Main Content */
    .main-content { margin-right: 260px; flex: 1; }
    .admin-topbar { background: white; padding: 16px 28px; border-bottom: 1px solid #E2E8F0; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 40; }
    .topbar-title { font-size: 20px; font-weight: 800; color: #1E293B; }
    .topbar-right { display: flex; align-items: center; gap: 12px; }
    .topbar-btn { width: 38px; height: 38px; border-radius: 10px; background: #F8FAFC; border: 1px solid #E2E8F0; display: flex; align-items: center; justify-content: center; font-size: 18px; cursor: pointer; transition: all 0.3s; text-decoration: none; position: relative; }
    .topbar-btn:hover { background: #EFF6FF; border-color: #3B82F6; }
    .topbar-badge { position: absolute; top: 4px; right: 4px; width: 8px; height: 8px; background: #EF4444; border-radius: 50%; border: 2px solid white; }
    .admin-main { padding: 28px; }
    /* Stat Cards */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 28px; }
    .stat-card { background: white; border-radius: 18px; padding: 22px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); transition: all 0.3s; border-top: 4px solid; }
    .stat-card:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
    .stat-card-blue { border-color: #1D4ED8; }
    .stat-card-green { border-color: #10B981; }
    .stat-card-amber { border-color: #F59E0B; }
    .stat-card-red { border-color: #EF4444; }
    .stat-icon-box { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 26px; margin-bottom: 16px; }
    .stat-icon-blue { background: #EFF6FF; }
    .stat-icon-green { background: #F0FDF4; }
    .stat-icon-amber { background: #FFFBEB; }
    .stat-icon-red { background: #FFF5F5; }
    .stat-value { font-size: 32px; font-weight: 900; color: #1E293B; }
    .stat-label { font-size: 13px; color: #94A3B8; font-weight: 600; margin-top: 4px; }
    .stat-trend { font-size: 12px; font-weight: 700; margin-top: 8px; display: flex; align-items: center; gap: 4px; }
    .trend-up { color: #10B981; }
    .trend-down { color: #EF4444; }
    /* Charts Row */
    .charts-row { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 28px; }
    .chart-card { background: white; border-radius: 18px; padding: 22px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
    .chart-title { font-size: 16px; font-weight: 800; color: #1E293B; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; }
    .chart-placeholder { height: 200px; background: linear-gradient(180deg, #EFF6FF 0%, #DBEAFE 100%); border-radius: 12px; display: flex; align-items: flex-end; padding: 16px; gap: 8px; overflow: hidden; }
    .chart-bar { flex: 1; border-radius: 6px 6px 0 0; transition: all 0.5s ease; cursor: pointer; position: relative; }
    .chart-bar:hover { opacity: 0.8; }
    .chart-bar-label { position: absolute; bottom: -20px; width: 100%; text-align: center; font-size: 10px; color: #94A3B8; font-weight: 600; }
    .donut-placeholder { width: 140px; height: 140px; border-radius: 50%; background: conic-gradient(#1D4ED8 0deg 216deg, #10B981 216deg 306deg, #F59E0B 306deg 330deg, #EF4444 330deg 360deg); margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; position: relative; }
    .donut-inner { width: 80px; height: 80px; background: white; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; }
    .donut-num { font-size: 20px; font-weight: 900; color: #1E293B; }
    .donut-label { font-size: 9px; color: #94A3B8; }
    .donut-legend { display: flex; flex-direction: column; gap: 8px; }
    .legend-item { display: flex; align-items: center; gap: 8px; font-size: 12px; color: #64748B; font-weight: 600; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    /* Tables */
    .tables-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }
    .table-card { background: white; border-radius: 18px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
    .table-header { padding: 18px 22px; border-bottom: 1px solid #F1F5F9; display: flex; align-items: center; justify-content: space-between; }
    .table-title { font-size: 15px; font-weight: 800; color: #1E293B; }
    .view-all-link { font-size: 13px; font-weight: 700; color: #1D4ED8; text-decoration: none; }
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th { background: #F8FAFC; padding: 12px 16px; text-align: right; font-size: 12px; font-weight: 700; color: #94A3B8; border-bottom: 1px solid #F1F5F9; }
    .data-table td { padding: 14px 16px; border-bottom: 1px solid #F8FAFC; font-size: 13px; color: #1E293B; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: #F8FAFC; }
    .status-pill { padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; display: inline-block; }
    .pill-active { background: #F0FDF4; color: #10B981; }
    .pill-pending { background: #FFFBEB; color: #D97706; }
    .pill-inactive { background: #F8FAFC; color: #94A3B8; }
    .pill-cancelled { background: #FFF5F5; color: #EF4444; }
    /* Activity Feed */
    .activity-card { background: white; border-radius: 18px; padding: 22px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 20px; }
    .activity-item { display: flex; align-items: flex-start; gap: 14px; padding: 12px 0; border-bottom: 1px solid #F8FAFC; }
    .activity-item:last-child { border-bottom: none; }
    .activity-icon { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
    .activity-content { flex: 1; }
    .activity-text { font-size: 13px; font-weight: 600; color: #1E293B; }
    .activity-time { font-size: 11px; color: #94A3B8; margin-top: 3px; }
    .activity-badge { font-size: 12px; font-weight: 700; padding: 3px 10px; border-radius: 8px; }
    /* Quick Actions Bar */
    .quick-actions-bar { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
    .quick-action-card { background: white; border-radius: 14px; padding: 16px 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); display: flex; align-items: center; gap: 12px; cursor: pointer; transition: all 0.3s; text-decoration: none; border: 2px solid transparent; }
    .quick-action-card:hover { border-color: #3B82F6; transform: translateY(-2px); }
    .qa-icon { font-size: 24px; }
    .qa-label { font-size: 14px; font-weight: 700; color: #1E293B; }
    /* Responsive */
    @media (max-width: 1024px) {
      .stats-grid { grid-template-columns: 1fr 1fr; }
      .charts-row { grid-template-columns: 1fr; }
      .tables-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .sidebar { display: none; }
      .main-content { margin-right: 0; }
      .stats-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
      .admin-main { padding: 16px; }
    }
  </style>
</head>
<body>
  <div class="admin-layout">
    <!-- Sidebar -->
    <div class="sidebar">
      <div class="sidebar-logo">
        <div class="logo-app">🚀 وصله</div>
        <div class="logo-sub">لوحة التحكم الإدارية</div>
      </div>

      <div class="sidebar-user">
        <div class="user-av">م</div>
        <div>
          <div class="user-av-name" id="adminName">المدير</div>
          <div class="user-av-role">مدير النظام</div>
        </div>
      </div>

      <div class="sidebar-section">
        <div class="sidebar-section-title">الرئيسية</div>
        <a href="/admin" class="sidebar-nav-item active">
          <span class="sidebar-nav-icon">📊</span>
          لوحة التحكم
        </a>
      </div>

      <div class="sidebar-section">
        <div class="sidebar-section-title">إدارة</div>
        <a href="/admin/orders" class="sidebar-nav-item">
          <span class="sidebar-nav-icon">📋</span>
          إدارة الطلبات
          <span class="nav-badge">12</span>
        </a>
        <a href="/admin/users" class="sidebar-nav-item">
          <span class="sidebar-nav-icon">👥</span>
          إدارة المستخدمين
        </a>
        <a href="/admin/drivers" class="sidebar-nav-item">
          <span class="sidebar-nav-icon">🚗</span>
          إدارة السائقين
          <span class="nav-badge green">5</span>
        </a>
        <a href="#" class="sidebar-nav-item" onclick="adminAlert('المتاجر')">
          <span class="sidebar-nav-icon">🏪</span>
          إدارة المتاجر
        </a>
      </div>

      <div class="sidebar-section">
        <div class="sidebar-section-title">المالية</div>
        <a href="#" class="sidebar-nav-item" onclick="adminAlert('المحافظ')">
          <span class="sidebar-nav-icon">💰</span>
          إدارة المحافظ
        </a>
        <a href="#" class="sidebar-nav-item" onclick="adminAlert('التقارير')">
          <span class="sidebar-nav-icon">📈</span>
          التقارير المالية
        </a>
        <a href="#" class="sidebar-nav-item" onclick="adminAlert('العروض')">
          <span class="sidebar-nav-icon">🎁</span>
          العروض والكوبونات
        </a>
      </div>

      <div class="sidebar-section">
        <div class="sidebar-section-title">النظام</div>
        <a href="#" class="sidebar-nav-item" onclick="adminAlert('الإشعارات')">
          <span class="sidebar-nav-icon">🔔</span>
          الإشعارات
        </a>
        <a href="#" class="sidebar-nav-item" onclick="adminAlert('الدعم')">
          <span class="sidebar-nav-icon">💬</span>
          الدعم الفني
        </a>
        <a href="#" class="sidebar-nav-item" onclick="adminAlert('الإعدادات')">
          <span class="sidebar-nav-icon">⚙️</span>
          إعدادات النظام
        </a>
        <a href="/login" class="sidebar-nav-item" onclick="adminLogout()">
          <span class="sidebar-nav-icon">🚪</span>
          تسجيل الخروج
        </a>
      </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Top Bar -->
      <div class="admin-topbar">
        <div class="topbar-title">📊 لوحة التحكم</div>
        <div class="topbar-right">
          <div style="font-size:13px;color:#64748B;font-weight:600">
            📅 <span id="currentDate"></span>
          </div>
          <a href="/home" class="topbar-btn" title="التطبيق">🚀</a>
          <div class="topbar-btn" style="cursor:pointer" onclick="showAdminNotifs()">
            🔔
            <div class="topbar-badge"></div>
          </div>
        </div>
      </div>

      <div class="admin-main">
        <!-- Quick Actions -->
        <div class="quick-actions-bar">
          <a href="/admin/orders" class="quick-action-card">
            <span class="qa-icon">➕</span>
            <span class="qa-label">إضافة طلب</span>
          </a>
          <a href="/admin/drivers" class="quick-action-card">
            <span class="qa-icon">🚗</span>
            <span class="qa-label">سائق جديد</span>
          </a>
          <div class="quick-action-card" onclick="generateReport()">
            <span class="qa-icon">📊</span>
            <span class="qa-label">تقرير اليوم</span>
          </div>
          <div class="quick-action-card" onclick="sendNotification()">
            <span class="qa-icon">🔔</span>
            <span class="qa-label">إرسال إشعار</span>
          </div>
          <div class="quick-action-card" onclick="adminAlert('العروض')">
            <span class="qa-icon">🎁</span>
            <span class="qa-label">كوبون خصم</span>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card stat-card-blue">
            <div class="stat-icon-box stat-icon-blue">📋</div>
            <div class="stat-value">1,284</div>
            <div class="stat-label">إجمالي الطلبات</div>
            <div class="stat-trend trend-up">↑ 12.5% هذا الشهر</div>
          </div>
          <div class="stat-card stat-card-green">
            <div class="stat-icon-box stat-icon-green">👥</div>
            <div class="stat-value">52,340</div>
            <div class="stat-label">إجمالي المستخدمين</div>
            <div class="stat-trend trend-up">↑ 8.3% هذا الشهر</div>
          </div>
          <div class="stat-card stat-card-amber">
            <div class="stat-icon-box stat-icon-amber">🚗</div>
            <div class="stat-value">342</div>
            <div class="stat-label">سائقون نشطون</div>
            <div class="stat-trend trend-up">↑ 5.2% هذا الشهر</div>
          </div>
          <div class="stat-card stat-card-red">
            <div class="stat-icon-box stat-icon-amber">💰</div>
            <div class="stat-value">284K</div>
            <div class="stat-label">إيرادات (جنيه)</div>
            <div class="stat-trend trend-up">↑ 15.8% هذا الشهر</div>
          </div>
        </div>

        <!-- Secondary Stats -->
        <div class="stats-grid" style="margin-bottom:28px">
          <div class="stat-card stat-card-blue" style="border-color:#7C3AED">
            <div class="stat-icon-box" style="background:#F5F3FF">⏳</div>
            <div class="stat-value" style="color:#7C3AED">12</div>
            <div class="stat-label">طلبات قيد التنفيذ</div>
            <div class="stat-trend" style="color:#7C3AED">🔴 الآن</div>
          </div>
          <div class="stat-card stat-card-green" style="border-color:#10B981">
            <div class="stat-icon-box stat-icon-green">✅</div>
            <div class="stat-value">1,198</div>
            <div class="stat-label">طلبات مكتملة</div>
            <div class="stat-trend trend-up">93.3% نسبة إكمال</div>
          </div>
          <div class="stat-card stat-card-amber" style="border-color:#0EA5E9">
            <div class="stat-icon-box" style="background:#F0F9FF">⭐</div>
            <div class="stat-value">4.8</div>
            <div class="stat-label">متوسط التقييم</div>
            <div class="stat-trend trend-up">↑ من 4.7</div>
          </div>
          <div class="stat-card stat-card-red">
            <div class="stat-icon-box stat-icon-red">❌</div>
            <div class="stat-value">74</div>
            <div class="stat-label">طلبات ملغاة</div>
            <div class="stat-trend trend-down">5.7% نسبة الإلغاء</div>
          </div>
        </div>

        <!-- Charts -->
        <div class="charts-row">
          <div class="chart-card">
            <div class="chart-title">
              📈 الطلبات اليومية (آخر 7 أيام)
              <select style="font-family:'Cairo',sans-serif;font-size:12px;border:1px solid #E2E8F0;border-radius:8px;padding:4px 8px;color:#64748B">
                <option>7 أيام</option>
                <option>30 يوم</option>
                <option>3 أشهر</option>
              </select>
            </div>
            <div style="padding-bottom: 24px; position: relative;">
              <div class="chart-placeholder">
                <div class="chart-bar" style="background:#1D4ED8;height:60%;"><div class="chart-bar-label">السبت</div></div>
                <div class="chart-bar" style="background:#3B82F6;height:80%;"><div class="chart-bar-label">الأحد</div></div>
                <div class="chart-bar" style="background:#1D4ED8;height:55%;"><div class="chart-bar-label">الاثنين</div></div>
                <div class="chart-bar" style="background:#3B82F6;height:95%;"><div class="chart-bar-label">الثلاثاء</div></div>
                <div class="chart-bar" style="background:#1D4ED8;height:70%;"><div class="chart-bar-label">الأربعاء</div></div>
                <div class="chart-bar" style="background:#60A5FA;height:45%;"><div class="chart-bar-label">الخميس</div></div>
                <div class="chart-bar" style="background:#1E3A8A;height:85%;"><div class="chart-bar-label">الجمعة</div></div>
              </div>
            </div>
          </div>

          <div class="chart-card">
            <div class="chart-title">🥧 توزيع الخدمات</div>
            <div style="text-align:center">
              <div class="donut-placeholder">
                <div class="donut-inner">
                  <div class="donut-num">100%</div>
                  <div class="donut-label">الكل</div>
                </div>
              </div>
              <div class="donut-legend">
                <div class="legend-item"><div class="legend-dot" style="background:#1D4ED8"></div>🏪 توصيل طلبات (60%)</div>
                <div class="legend-item"><div class="legend-dot" style="background:#10B981"></div>🚗 مشاوير (25%)</div>
                <div class="legend-item"><div class="legend-dot" style="background:#F59E0B"></div>✈️ مطار (8%)</div>
                <div class="legend-item"><div class="legend-dot" style="background:#EF4444"></div>📦 أخرى (7%)</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Tables Row -->
        <div class="tables-row">
          <!-- Recent Orders -->
          <div class="table-card">
            <div class="table-header">
              <div class="table-title">📋 آخر الطلبات</div>
              <a href="/admin/orders" class="view-all-link">عرض الكل →</a>
            </div>
            <table class="data-table">
              <thead>
                <tr>
                  <th>رقم الطلب</th>
                  <th>الخدمة</th>
                  <th>المبلغ</th>
                  <th>الحالة</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>#4523</strong></td>
                  <td>✈️ مطار</td>
                  <td>150 جنيه</td>
                  <td><span class="status-pill pill-active">قيد التنفيذ</span></td>
                </tr>
                <tr>
                  <td><strong>#4522</strong></td>
                  <td>🏪 توصيل</td>
                  <td>45 جنيه</td>
                  <td><span class="status-pill pill-active" style="background:#F0FDF4;color:#10B981">مكتمل ✅</span></td>
                </tr>
                <tr>
                  <td><strong>#4521</strong></td>
                  <td>🚗 مشوار</td>
                  <td>80 جنيه</td>
                  <td><span class="status-pill pill-active" style="background:#F0FDF4;color:#10B981">مكتمل ✅</span></td>
                </tr>
                <tr>
                  <td><strong>#4520</strong></td>
                  <td>🏪 توصيل</td>
                  <td>35 جنيه</td>
                  <td><span class="status-pill pill-pending">معلق ⏳</span></td>
                </tr>
                <tr>
                  <td><strong>#4519</strong></td>
                  <td>✈️ مطار</td>
                  <td>250 جنيه</td>
                  <td><span class="status-pill pill-active" style="background:#F0FDF4;color:#10B981">مكتمل ✅</span></td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Recent Users -->
          <div class="table-card">
            <div class="table-header">
              <div class="table-title">👥 آخر المستخدمين</div>
              <a href="/admin/users" class="view-all-link">عرض الكل →</a>
            </div>
            <table class="data-table">
              <thead>
                <tr>
                  <th>المستخدم</th>
                  <th>المحافظة</th>
                  <th>الطلبات</th>
                  <th>الحالة</th>
                </tr>
