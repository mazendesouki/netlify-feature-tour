  <script>
    function viewUser(name) { alert('👁️ ملف المستخدم: ' + name + '\n\n📱 الطلبات: 24\n💰 إجمالي الإنفاق: 1,840 جنيه\n⭐ التقييم: 4.8\n📅 عضو منذ: يناير 2024'); }
    function manageWallet(name) { alert('💰 محفظة ' + name + '\n\nالرصيد الحالي: 250 جنيه\nإجمالي الشحن: 1,500 جنيه\nإجمالي الإنفاق: 1,250 جنيه\n\nإجراءات:\n• إضافة رصيد\n• خصم رصيد\n• تجميد المحفظة'); }
    function sendMsg(name) { const msg = prompt('💬 رسالة لـ ' + name + ':'); if (msg) alert('✅ تم إرسال الرسالة لـ ' + name); }
    function blockUser(name) { if (confirm('🚫 هل تريد حظر ' + name + '؟')) alert('✅ تم حظر المستخدم ' + name); }
    function unblockUser(name) { if (confirm('✅ هل تريد رفع الحظر عن ' + name + '؟')) alert('✅ تم رفع الحظر'); }
    function addUser() { alert('➕ إضافة مستخدم جديد'); }
    function exportUsers() { alert('📥 جاري تصدير بيانات المستخدمين...'); }
    function selectAll() { document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = true); }
  </script>
</body>
</html>
