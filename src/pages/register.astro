<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>إنشاء حساب - وصله</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/wslha.css">
  <style>
    body { padding: 0; background: linear-gradient(135deg, #1E3A8A 0%, #1D4ED8 100%); min-height: 100vh; }
    .reg-header { padding: 24px; display: flex; align-items: center; }
    .back-btn { color: rgba(255,255,255,0.85); font-size: 15px; font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 8px; }
    .reg-hero { padding: 16px 24px 28px; text-align: center; }
    .reg-logo { width: 72px; height: 72px; background: rgba(255,255,255,0.15); border-radius: 22px; display: flex; align-items: center; justify-content: center; font-size: 36px; margin: 0 auto 16px; border: 2px solid rgba(255,255,255,0.3); }
    .reg-title { font-size: 26px; font-weight: 900; color: white; margin-bottom: 6px; }
    .reg-subtitle { font-size: 14px; color: rgba(255,255,255,0.75); }
    .reg-card { background: white; border-radius: 32px 32px 0 0; padding: 28px 24px 40px; min-height: 550px; }
    .steps-indicator { display: flex; justify-content: center; gap: 8px; margin-bottom: 28px; }
    .step-indicator { width: 36px; height: 8px; border-radius: 4px; background: #E2E8F0; transition: all 0.35s cubic-bezier(.4,0,.2,1); }
    .step-indicator.active { width: 64px; background: #1D4ED8; }
    .step-indicator.done { background: #10B981; width: 36px; }
    .step-content { display: none; }
    .step-content.active { display: block; animation: fadeInUp 0.35s ease; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
    .step-title { font-size: 20px; font-weight: 800; color: #1E293B; margin-bottom: 20px; }
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 14px; font-weight: 700; color: #374151; margin-bottom: 8px; }
    .form-control { width: 100%; padding: 14px 16px; border: 2px solid #E2E8F0; border-radius: 12px; font-family: 'Cairo', sans-serif; font-size: 15px; color: #1E293B; background: #F8FAFC; outline: none; transition: all 0.25s; box-sizing: border-box; }
    .form-control:focus { border-color: #1D4ED8; background: white; box-shadow: 0 0 0 4px rgba(29,78,216,0.1); }
    .form-control.error { border-color: #EF4444; background: #FFF5F5; }
    .field-error { font-size: 12px; color: #EF4444; font-weight: 600; margin-top: 5px; display: none; }
    .field-error.show { display: block; }
    .phone-prefix { display: flex; gap: 8px; }
    .prefix-select { width: 110px; padding: 14px 12px; border: 2px solid #E2E8F0; border-radius: 12px; font-family: 'Cairo', sans-serif; font-size: 14px; background: #F8FAFC; flex-shrink: 0; outline: none; }
    .gender-btns { display: flex; gap: 12px; }
    .gender-btn { flex: 1; padding: 14px; border: 2px solid #E2E8F0; border-radius: 14px; background: white; font-family: 'Cairo', sans-serif; font-size: 15px; font-weight: 700; color: #475569; cursor: pointer; transition: all 0.25s; text-align: center; }
    .gender-btn.selected { border-color: #1D4ED8; background: #EFF6FF; color: #1D4ED8; }
    .next-btn, .submit-btn { width: 100%; padding: 16px; background: linear-gradient(135deg, #1E3A8A, #1D4ED8); color: white; border: none; border-radius: 14px; font-family: 'Cairo', sans-serif; font-size: 17px; font-weight: 800; cursor: pointer; box-shadow: 0 4px 20px rgba(29,78,216,0.35); margin-top: 8px; transition: all 0.25s; }
    .next-btn:hover, .submit-btn:hover { transform: translateY(-2px); }
    .back-step-btn { width: 100%; padding: 12px; background: #F1F5F9; color: #64748B; border: none; border-radius: 14px; font-family: 'Cairo', sans-serif; font-size: 15px; font-weight: 700; cursor: pointer; margin-top: 8px; }
    .password-strength { margin-top: 8px; }
    .strength-bar { height: 5px; border-radius: 5px; background: #E2E8F0; margin-bottom: 5px; overflow: hidden; }
    .strength-fill { height: 100%; border-radius: 5px; transition: all 0.35s; width: 0; }
    .strength-label { font-size: 12px; font-weight: 700; }
    .benefits-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
    .benefit-item { display: flex; align-items: center; gap: 12px; padding: 12px 14px; background: #F8FAFC; border-radius: 14px; border: 1px solid #E2E8F0; }
    .benefit-icon { font-size: 22px; flex-shrink: 0; }
    .benefit-text { font-size: 14px; font-weight: 700; color: #1E293B; }
    .benefit-sub { font-size: 12px; color: #94A3B8; margin-top: 1px; }
    .terms-check { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
    .terms-check input { width: 18px; height: 18px; accent-color: #1D4ED8; margin-top: 2px; flex-shrink: 0; cursor: pointer; }
    .terms-text { font-size: 13px; color: #64748B; line-height: 1.6; }
    .terms-text a { color: #1D4ED8; font-weight: 700; text-decoration: none; }
    .otp-inputs { display: flex; gap: 12px; justify-content: center; margin: 24px 0; direction: ltr; }
    .otp-input { width: 60px; height: 64px; border: 2px solid #E2E8F0; border-radius: 16px; text-align: center; font-family: 'Cairo', sans-serif; font-size: 26px; font-weight: 900; color: #1E293B; outline: none; transition: all 0.25s; background: #F8FAFC; }
    .otp-input:focus { border-color: #1D4ED8; background: white; box-shadow: 0 0 0 4px rgba(29,78,216,0.15); }
    .otp-input.filled { border-color: #10B981; background: #F0FDF4; color: #059669; }
    .otp-hint { text-align: center; font-size: 13px; background: #F0F9FF; color: #0369A1; padding: 10px 16px; border-radius: 10px; margin-bottom: 16px; border: 1px solid #BAE6FD; }
    .otp-resend { text-align: center; font-size: 13px; color: #64748B; margin-bottom: 12px; }
    .otp-resend a { color: #1D4ED8; font-weight: 700; text-decoration: none; }
    .phone-display { text-align: center; font-size: 14px; color: #475569; margin-bottom: 8px; font-weight: 600; }
    .login-link { text-align: center; margin-top: 20px; font-size: 14px; color: #64748B; }
    .login-link a { color: #1D4ED8; font-weight: 800; text-decoration: none; }
    .success-toast { position: fixed; top: 20px; right: 16px; left: 16px; background: #10B981; color: white; padding: 16px 20px; border-radius: 16px; font-weight: 700; font-size: 15px; box-shadow: 0 8px 25px rgba(16,185,129,0.45); transform: translateY(-120px); transition: all 0.4s cubic-bezier(.4,0,.2,1); z-index: 999; text-align: center; }
    .success-toast.show { transform: translateY(0); }
    .error-toast { background: #EF4444 !important; }
  </style>
</head>
<body>
  <div class="reg-header">
    <a href="/" class="back-btn" id="backHomeBtn">← العودة للرئيسية</a>
  </div>

  <div class="reg-hero">
    <div class="reg-logo">🚀</div>
    <div class="reg-title">إنشاء حساب جديد</div>
    <div class="reg-subtitle">انضم لآلاف المستخدمين وابدأ رحلتك مع وصله</div>
  </div>

  <div class="reg-card">
    <div class="steps-indicator">
      <div class="step-indicator active" id="ind-1"></div>
      <div class="step-indicator" id="ind-2"></div>
      <div class="step-indicator" id="ind-3"></div>
    </div>

    <!-- Step 1 -->
    <div class="step-content active" id="step-1">
      <div class="step-title">👋 معلوماتك الأساسية</div>
      <div class="form-group">
        <label class="form-label">👤 الاسم الكامل</label>
        <input type="text" class="form-control" placeholder="محمد أحمد علي" id="fullName" autocomplete="name">
        <div class="field-error" id="nameErr">يرجى إدخال الاسم الكامل</div>
      </div>
      <div class="form-group">
        <label class="form-label">📱 رقم الهاتف</label>
        <div class="phone-prefix">
          <select class="prefix-select"><option>🇪🇬 +20</option></select>
          <input type="tel" class="form-control" placeholder="01XXXXXXXXX" id="phone" autocomplete="tel">
        </div>
        <div class="field-error" id="phoneErr">يرجى إدخال رقم هاتف صحيح (01XXXXXXXXX)</div>
      </div>
      <div class="form-group">
        <label class="form-label">📧 البريد الإلكتروني (اختياري)</label>
        <input type="email" class="form-control" placeholder="example@gmail.com" id="email" autocomplete="email">
        <div class="field-error" id="emailErr">صيغة البريد الإلكتروني غير صحيحة</div>
      </div>
      <div class="form-group">
        <label class="form-label">الجنس</label>
        <div class="gender-btns">
          <button class="gender-btn" onclick="selectGender(this,'male')" type="button">👨 ذكر</button>
          <button class="gender-btn" onclick="selectGender(this,'female')" type="button">👩 أنثى</button>
        </div>
        <div class="field-error" id="genderErr">يرجى اختيار الجنس</div>
      </div>
      <button class="next-btn" onclick="goStep(2)" type="button">التالي ←</button>
      <div class="login-link">لديك حساب؟ <a href="/login" id="loginLink">تسجيل الدخول</a></div>
    </div>

    <!-- Step 2 -->
    <div class="step-content" id="step-2">
      <div class="step-title">🔒 كلمة المرور والمميزات</div>
      <div class="form-group">
        <label class="form-label">🔑 كلمة المرور</label>
        <input type="password" class="form-control" placeholder="6 أحرف على الأقل" id="password" oninput="checkStrength(this.value)">
        <div class="password-strength">
          <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
          <span class="strength-label" id="strengthLabel" style="color:#94A3B8">أدخل كلمة المرور</span>
        </div>
        <div class="field-error" id="pwdErr">كلمة المرور يجب أن تكون 6 أحرف على الأقل</div>
      </div>
      <div class="form-group">
        <label class="form-label">🔑 تأكيد كلمة المرور</label>
        <input type="password" class="form-control" placeholder="أعد إدخال كلمة المرور" id="confirmPassword">
        <div class="field-error" id="confirmErr">كلمتا المرور غير متطابقتين</div>
      </div>
      <div class="benefits-list">
        <div class="benefit-item"><span class="benefit-icon">🚚</span><div><div class="benefit-text">توصيل من المتاجر المحلية</div><div class="benefit-sub">آلاف المتاجر في مصر</div></div></div>
        <div class="benefit-item"><span class="benefit-icon">🚗</span><div><div class="benefit-text">مشاوير داخل وبين المحافظات</div><div class="benefit-sub">27 محافظة في جميع أنحاء مصر</div></div></div>
        <div class="benefit-item"><span class="benefit-icon">✈️</span><div><div class="benefit-text">خدمة توصيل المطار</div><div class="benefit-sub">جميع المطارات المصرية</div></div></div>
        <div class="benefit-item"><span class="benefit-icon">👛</span><div><div class="benefit-text">محفظة إلكترونية متكاملة</div><div class="benefit-sub">شحن رصيد وسحب وتحويل</div></div></div>
      </div>
      <div class="terms-check">
        <input type="checkbox" id="terms">
        <span class="terms-text">أوافق على <a href="#">شروط الاستخدام</a> و<a href="#">سياسة الخصوصية</a> لتطبيق وصله</span>
      </div>
      <div class="field-error" id="termsErr">يجب الموافقة على الشروط للمتابعة</div>
      <button class="next-btn" onclick="goStep(3)" type="button">التالي ←</button>
      <button class="back-step-btn" onclick="goStep(1)" type="button">← رجوع</button>
    </div>

    <!-- Step 3 -->
    <div class="step-content" id="step-3">
      <div class="step-title">📲 تأكيد رقم الهاتف</div>
      <p class="phone-display">تم إرسال رمز التحقق على: <strong id="phoneDisplay"></strong></p>
      <p style="font-size:13px;color:#64748B;text-align:center;margin-bottom:8px;">أدخل الرمز المكون من 4 أرقام</p>
      <div class="otp-inputs">
        <input type="text" inputmode="numeric" class="otp-input" maxlength="1" id="otp1">
        <input type="text" inputmode="numeric" class="otp-input" maxlength="1" id="otp2">
        <input type="text" inputmode="numeric" class="otp-input" maxlength="1" id="otp3">
        <input type="text" inputmode="numeric" class="otp-input" maxlength="1" id="otp4">
      </div>
      <div class="otp-hint">💡 للتجربة: الرمز هو <strong>1234</strong></div>
      <div class="otp-resend">
        لم يصلك الرمز؟
        <a href="#" id="resendLink" onclick="resendOTP(event)">إعادة الإرسال</a>
        <span id="timer"></span>
      </div>
      <button class="submit-btn" onclick="submitRegister()" type="button" id="submitBtn">إنشاء الحساب ✅</button>
      <button class="back-step-btn" onclick="goStep(2)" type="button">← رجوع</button>
    </div>
  </div>

  <div class="success-toast" id="toast"></div>

  <script>
    const BASE = location.pathname.startsWith('/netlify-feature-tour') ? '/netlify-feature-tour' : '';
    document.getElementById('backHomeBtn').href = BASE + '/';
    document.getElementById('loginLink').href = BASE + '/login';

    let currentStep = 1, gender = '', timerInterval;

    function selectGender(btn, value) {
      document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      gender = value;
      showErr('genderErr', false);
    }

    function showErr(id, show) {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('show', show);
    }

    function setFieldError(inputId, errId, hasError) {
      const input = document.getElementById(inputId);
      if (input) input.classList.toggle('error', hasError);
      showErr(errId, hasError);
    }

    function goStep(step) {
      if (step > currentStep) {
        if (currentStep === 1) {
          const name = document.getElementById('fullName').value.trim();
          const phone = document.getElementById('phone').value.trim().replace(/\s/g,'');
          const email = document.getElementById('email').value.trim();
          let ok = true;
          setFieldError('fullName','nameErr',!name); if(!name) ok=false;
          const phoneOk = /^01[0-9]{9}$/.test(phone);
          setFieldError('phone','phoneErr',!phoneOk); if(!phoneOk) ok=false;
          const emailOk = !email || /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
          setFieldError('email','emailErr',!emailOk); if(!emailOk) ok=false;
          showErr('genderErr',!gender); if(!gender) ok=false;
          if(!ok) return;
          document.getElementById('phoneDisplay').textContent = '+20' + phone;
        }
        if (currentStep === 2) {
          const pwd = document.getElementById('password').value;
          const conf = document.getElementById('confirmPassword').value;
          const terms = document.getElementById('terms').checked;
          let ok = true;
          setFieldError('password','pwdErr',pwd.length<6); if(pwd.length<6) ok=false;
          setFieldError('confirmPassword','confirmErr',pwd!==conf); if(pwd!==conf) ok=false;
          showErr('termsErr',!terms); if(!terms) ok=false;
          if(!ok) return;
          startTimer();
        }
      }

      // Update step indicators
      const prev = currentStep;
      document.getElementById('step-' + prev).classList.remove('active');

      if (step < prev) {
        for (let i = step; i <= prev; i++) {
          const ind = document.getElementById('ind-' + i);
          if (ind) ind.classList.remove('active','done');
        }
      } else {
        const prevInd = document.getElementById('ind-' + prev);
        prevInd.classList.remove('active');
        prevInd.classList.add('done');
      }

      currentStep = step;
      document.getElementById('step-' + step).classList.add('active');
      document.getElementById('ind-' + step).classList.add('active');

      // Mark all previous as done
      for (let i = 1; i < step; i++) {
        const ind = document.getElementById('ind-' + i);
        if (ind) { ind.classList.remove('active'); ind.classList.add('done'); }
      }
    }

    function checkStrength(value) {
      const fill = document.getElementById('strengthFill');
      const label = document.getElementById('strengthLabel');
      let s = 0;
      if (value.length >= 6) s++;
      if (value.length >= 10) s++;
      if (/[A-Z]/.test(value)) s++;
      if (/[0-9]/.test(value)) s++;
      if (/[^A-Za-z0-9]/.test(value)) s++;
      fill.style.width = (!value ? 0 : (s/5)*100) + '%';
      if (!value) { label.textContent='أدخل كلمة المرور'; label.style.color='#94A3B8'; return; }
      const map = [[1,'#EF4444','😟 ضعيفة جداً'],[2,'#F59E0B','😐 متوسطة'],[3,'#3B82F6','😊 جيدة'],[5,'#10B981','💪 ممتازة']];
      const [,color,text] = map.find(([n])=>s<=n) || map[3];
      fill.style.background = color; label.textContent = text; label.style.color = color;
    }

    const otpIds = ['otp1','otp2','otp3','otp4'];
    otpIds.forEach((id, idx) => {
      const input = document.getElementById(id);
      input.addEventListener('input', function() {
        this.value = this.value.replace(/\D/g,'');
        this.classList.toggle('filled', this.value.length === 1);
        if (this.value && idx < 3) document.getElementById(otpIds[idx+1]).focus();
        if (otpIds.map(i=>document.getElementById(i).value).join('') === '1234') setTimeout(submitRegister,400);
      });
      input.addEventListener('keydown', function(e) {
        if (e.key==='Backspace' && !this.value && idx>0) {
          const prev = document.getElementById(otpIds[idx-1]);
          prev.value=''; prev.classList.remove('filled'); prev.focus();
        }
      });
    });

    function startTimer() {
      const link = document.getElementById('resendLink');
      const timerEl = document.getElementById('timer');
      link.style.pointerEvents='none'; link.style.opacity='0.5';
      let secs=60;
      clearInterval(timerInterval);
      timerEl.textContent = ' ('+secs+'ث)';
      timerInterval = setInterval(()=>{
        secs--;
        timerEl.textContent = ' ('+secs+'ث)';
        if(secs<=0){ clearInterval(timerInterval); timerEl.textContent=''; link.style.pointerEvents=''; link.style.opacity=''; }
      },1000);
    }

    function resendOTP(e) {
      e.preventDefault();
      showToast('📱 تم إرسال رمز التحقق مرة أخرى');
      startTimer();
    }

    function submitRegister() {
      const otp = otpIds.map(id=>document.getElementById(id).value).join('');
      if (otp !== '1234') { showToast('❌ رمز التحقق غير صحيح. جرّب: 1234', true); return; }
      const btn = document.getElementById('submitBtn');
      btn.disabled=true; btn.textContent='⏳ جارٍ إنشاء الحساب...';
      localStorage.setItem('wslha_user', JSON.stringify({
        name: document.getElementById('fullName').value.trim(),
        email: document.getElementById('email').value.trim(),
        phone: '+20' + document.getElementById('phone').value.trim(),
        role: 'user', gender, balance: 0,
        joinDate: new Date().toLocaleDateString('ar-EG')
      }));
      showToast('🎉 تم إنشاء حسابك بنجاح! مرحباً بك في وصله!');
      setTimeout(()=>{ window.location.href = BASE+'/home'; }, 1800);
    }

    function showToast(msg, isError=false) {
      const t = document.getElementById('toast');
      t.textContent=msg;
      t.className='success-toast'+(isError?' error-toast':'');
      t.classList.add('show');
      setTimeout(()=>t.classList.remove('show'),3200);
    }
  </script>
</body>
</html>
