---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>إنشاء حساب - وصله</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/wslha.css">
  <style>
    body { padding: 0; background: linear-gradient(135deg, #1E3A8A 0%, #1D4ED8 100%); min-height: 100vh; }
    .reg-header { padding: 24px; display: flex; align-items: center; }
    .back-btn { color: rgba(255,255,255,0.85); font-size: 15px; font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 8px; }
    .reg-hero { padding: 16px 24px 28px; text-align: center; }
    .reg-logo { width: 72px; height: 72px; background: rgba(255,255,255,0.15); border-radius: 22px; display: flex; align-items: center; justify-content: center; font-size: 36px; margin: 0 auto 16px; border: 2px solid rgba(255,255,255,0.3); }
    .reg-title { font-size: 26px; font-weight: 900; color: white; margin-bottom: 6px; }
    .reg-subtitle { font-size: 14px; color: rgba(255,255,255,0.75); }
    .reg-card { background: white; border-radius: 32px 32px 0 0; padding: 28px 24px 40px; min-height: 550px; }
    .steps-indicator { display: flex; justify-content: center; gap: 8px; margin-bottom: 28px; }
    .step-indicator { width: 36px; height: 8px; border-radius: 4px; background: #E2E8F0; transition: all 0.3s; }
    .step-indicator.active { width: 64px; background: #1D4ED8; }
    .step-indicator.done { background: #10B981; width: 36px; }
    .step-content { display: none; }
    .step-content.active { display: block; animation: fadeIn 0.3s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .step-title { font-size: 20px; font-weight: 800; color: #1E293B; margin-bottom: 20px; }
    .phone-prefix { display: flex; gap: 8px; }
    .prefix-select { width: 110px; padding: 14px 12px; border: 2px solid #E2E8F0; border-radius: 12px; font-family: 'Cairo', sans-serif; font-size: 14px; background: #F8FAFC; flex-shrink: 0; outline: none; }
    .gender-btns { display: flex; gap: 12px; }
    .gender-btn { flex: 1; padding: 14px; border: 2px solid #E2E8F0; border-radius: 14px; background: white; font-family: 'Cairo', sans-serif; font-size: 15px; font-weight: 700; color: #475569; cursor: pointer; transition: all 0.3s; text-align: center; }
    .gender-btn.selected, .gender-btn:hover { border-color: #1D4ED8; background: #EFF6FF; color: #1D4ED8; }
    .next-btn, .submit-btn { width: 100%; padding: 16px; background: linear-gradient(135deg, #1E3A8A, #1D4ED8); color: white; border: none; border-radius: 14px; font-family: 'Cairo', sans-serif; font-size: 17px; font-weight: 800; cursor: pointer; box-shadow: 0 4px 20px rgba(29,78,216,0.35); margin-top: 8px; transition: all 0.3s; }
    .next-btn:hover, .submit-btn:hover { transform: translateY(-2px); }
    .back-step-btn { width: 100%; padding: 12px; background: #F8FAFC; color: #64748B; border: none; border-radius: 14px; font-family: 'Cairo', sans-serif; font-size: 15px; font-weight: 700; cursor: pointer; margin-top: 8px; }
    .terms-check { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 20px; }
    .terms-check input { width: 18px; height: 18px; accent-color: #1D4ED8; margin-top: 2px; flex-shrink: 0; }
    .terms-text { font-size: 13px; color: #64748B; line-height: 1.6; }
    .terms-text a { color: #1D4ED8; font-weight: 700; text-decoration: none; }
    .password-strength { margin-top: 8px; }
    .strength-bar { height: 4px; border-radius: 4px; background: #E2E8F0; margin-bottom: 4px; overflow: hidden; }
    .strength-fill { height: 100%; border-radius: 4px; transition: all 0.3s; width: 0; }
    .strength-label { font-size: 12px; font-weight: 700; }
    .benefits-list { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
    .benefit-item { display: flex; align-items: center; gap: 12px; padding: 14px; background: #F8FAFC; border-radius: 14px; border: 1px solid #E2E8F0; }
    .benefit-icon { font-size: 24px; }
    .benefit-text { font-size: 14px; font-weight: 600; color: #1E293B; }
    .benefit-sub { font-size: 12px; color: #94A3B8; margin-top: 2px; }
    .otp-inputs { display: flex; gap: 12px; justify-content: center; margin: 24px 0; }
    .otp-input { width: 56px; height: 60px; border: 2px solid #E2E8F0; border-radius: 14px; text-align: center; font-family: 'Cairo', sans-serif; font-size: 24px; font-weight: 900; color: #1E293B; outline: none; transition: all 0.3s; }
    .otp-input:focus { border-color: #1D4ED8; box-shadow: 0 0 0 4px rgba(29,78,216,0.15); }
    .otp-resend { text-align: center; font-size: 13px; color: #64748B; margin-bottom: 16px; }
    .otp-resend a { color: #1D4ED8; font-weight: 700; text-decoration: none; }
    .login-link { text-align: center; margin-top: 20px; font-size: 14px; color: #64748B; }
    .login-link a { color: #1D4ED8; font-weight: 800; text-decoration: none; }
    .success-toast { position: fixed; top: 20px; right: 20px; left: 20px; background: #10B981; color: white; padding: 16px 20px; border-radius: 14px; font-weight: 700; font-size: 15px; box-shadow: 0 8px 25px rgba(16,185,129,0.4); transform: translateY(-100px); transition: all 0.4s; z-index: 999; text-align: center; }
    .success-toast.show { transform: translateY(0); }
  </style>
</head>
<body>
  <div class="reg-header">
    <a href="/" class="back-btn">← العودة للرئيسية</a>
  </div>

  <div class="reg-hero">
    <div class="reg-logo">🚀</div>
    <div class="reg-title">إنشاء حساب جديد</div>
    <div class="reg-subtitle">انضم لآلاف المستخدمين وابدأ رحلتك مع وصله</div>
  </div>

  <div class="reg-card">
    <!-- Step Indicators -->
    <div class="steps-indicator">
      <div class="step-indicator active" id="ind-1"></div>
      <div class="step-indicator" id="ind-2"></div>
      <div class="step-indicator" id="ind-3"></div>
    </div>

    <!-- Step 1: Basic Info -->
    <div class="step-content active" id="step-1">
      <div class="step-title">👋 معلوماتك الأساسية</div>

      <div class="form-group">
        <label class="form-label">👤 الاسم الكامل</label>
        <input type="text" class="form-control" placeholder="محمد أحمد علي" id="fullName">
      </div>

      <div class="form-group">
        <label class="form-label">📱 رقم الهاتف</label>
        <div class="phone-prefix">
          <select class="prefix-select">
            <option>🇪🇬 +20</option>
          </select>
          <input type="tel" class="form-control" placeholder="01XXXXXXXXX" id="phone">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">📧 البريد الإلكتروني</label>
        <input type="email" class="form-control" placeholder="example@gmail.com" id="email">
      </div>

      <div class="form-group">
        <label class="form-label">⚧ الجنس</label>
        <div class="gender-btns">
          <button class="gender-btn" onclick="selectGender(this, 'male')">👨 ذكر</button>
          <button class="gender-btn" onclick="selectGender(this, 'female')">👩 أنثى</button>
        </div>
      </div>

      <button class="next-btn" onclick="goStep(2)">التالي ←</button>
      <div class="login-link">لديك حساب؟ <a href="/login">تسجيل الدخول</a></div>
    </div>

    <!-- Step 2: Password & Benefits -->
    <div class="step-content" id="step-2">
      <div class="step-title">🔒 كلمة المرور والمميزات</div>

      <div class="form-group">
        <label class="form-label">🔑 كلمة المرور</label>
        <input type="password" class="form-control" placeholder="8 أحرف على الأقل" id="password" oninput="checkStrength(this.value)">
        <div class="password-strength">
          <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
          <span class="strength-label" id="strengthLabel" style="color:#94A3B8">أدخل كلمة المرور</span>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">🔑 تأكيد كلمة المرور</label>
        <input type="password" class="form-control" placeholder="أعد إدخال كلمة المرور" id="confirmPassword">
      </div>

      <div class="benefits-list">
        <div class="benefit-item">
          <span class="benefit-icon">🚚</span>
          <div><div class="benefit-text">توصيل الطلبات من المتاجر</div><div class="benefit-sub">آلاف المتاجر المحلية في مصر</div></div>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">🚗</span>
          <div><div class="benefit-text">مشاوير داخل وبين المحافظات</div><div class="benefit-sub">27 محافظة في جميع أنحاء مصر</div></div>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">✈️</span>
          <div><div class="benefit-text">خدمة توصيل المطار</div><div class="benefit-sub">جميع المطارات المصرية</div></div>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">👛</span>
          <div><div class="benefit-text">محفظة إلكترونية متكاملة</div><div class="benefit-sub">شحن رصيد وسحب وتحويل</div></div>
        </div>
      </div>

      <div class="terms-check">
        <input type="checkbox" id="terms">
        <span class="terms-text">أوافق على <a href="#">شروط الاستخدام</a> و<a href="#">سياسة الخصوصية</a> لتطبيق وصله</span>
      </div>

      <button class="next-btn" onclick="goStep(3)">التالي ←</button>
      <button class="back-step-btn" onclick="goStep(1)">← رجوع</button>
    </div>

    <!-- Step 3: OTP Verification -->
    <div class="step-content" id="step-3">
      <div class="step-title">📲 تأكيد رقم الهاتف</div>
      <p style="font-size: 14px; color: #64748B; margin-bottom: 20px; text-align: center;">
        تم إرسال رمز التحقق المكون من 4 أرقام على رقمك المسجل
      </p>

      <div class="otp-inputs">
        <input type="text" class="otp-input" maxlength="1" id="otp1" oninput="moveOTP(this, 'otp2')">
        <input type="text" class="otp-input" maxlength="1" id="otp2" oninput="moveOTP(this, 'otp3')">
        <input type="text" class="otp-input" maxlength="1" id="otp3" oninput="moveOTP(this, 'otp4')">
        <input type="text" class="otp-input" maxlength="1" id="otp4" oninput="checkOTP()">
      </div>

      <div class="otp-resend">
        لم يصلك الرمز؟ <a href="#" onclick="resendOTP()">إعادة الإرسال</a>
        <span id="timer" style="color:#94A3B8"> (60 ثانية)</span>
      </div>

      <p style="text-align:center; font-size: 13px; color: #94A3B8; margin-bottom: 16px; background: #F8FAFC; padding: 10px; border-radius: 10px;">
        💡 للاختبار: ادخل الرمز <strong>1234</strong>
      </p>

      <button class="submit-btn" onclick="submitRegister()">إنشاء الحساب ✅</button>
      <button class="back-step-btn" onclick="goStep(2)">← رجوع</button>
    </div>
  </div>

  <div class="success-toast" id="toast"></div>

  <script>
    let currentStep = 1;
    let gender = '';
    let timerInterval;

    function selectGender(btn, value) {
      document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      gender = value;
    }

    function goStep(step) {
      if (step === 2) {
        const name = document.getElementById('fullName').value;
        const phone = document.getElementById('phone').value;
        if (!name || !phone || !gender) {
          alert('⚠️ يرجى ملء جميع الحقول واختيار الجنس');
          return;
        }
      }
      if (step === 3) {
        const pwd = document.getElementById('password').value;
        const confirm = document.getElementById('confirmPassword').value;
        const terms = document.getElementById('terms').checked;
        if (pwd.length < 6) { alert('⚠️ كلمة المرور يجب أن تكون 6 أحرف على الأقل'); return; }
        if (pwd !== confirm) { alert('⚠️ كلمتا المرور غير متطابقتين'); return; }
        if (!terms) { alert('⚠️ يجب الموافقة على شروط الاستخدام'); return; }
        startTimer();
      }

      document.getElementById('step-' + currentStep).classList.remove('active');
      document.getElementById('ind-' + currentStep).classList.remove('active');
      document.getElementById('ind-' + currentStep).classList.add('done');
      currentStep = step;
      document.getElementById('step-' + currentStep).classList.add('active');
      document.getElementById('ind-' + currentStep).classList.add('active');
    }

    function checkStrength(value) {
      const fill = document.getElementById('strengthFill');
      const label = document.getElementById('strengthLabel');
      let strength = 0;
      if (value.length >= 6) strength++;
      if (value.length >= 10) strength++;
      if (/[A-Z]/.test(value)) strength++;
      if (/[0-9]/.test(value)) strength++;
      if (/[^A-Za-z0-9]/.test(value)) strength++;

      const pct = (strength / 5) * 100;
      fill.style.width = pct + '%';
      if (strength <= 1) { fill.style.background = '#EF4444'; label.textContent = '😟 ضعيفة جداً'; label.style.color = '#EF4444'; }
      else if (strength <= 2) { fill.style.background = '#F59E0B'; label.textContent = '😐 متوسطة'; label.style.color = '#F59E0B'; }
      else if (strength <= 3) { fill.style.background = '#3B82F6'; label.textContent = '😊 جيدة'; label.style.color = '#3B82F6'; }
      else { fill.style.background = '#10B981'; label.textContent = '💪 ممتازة'; label.style.color = '#10B981'; }
    }

    function moveOTP(input, nextId) {
      if (input.value.length === 1 && nextId) {
        document.getElementById(nextId).focus();
      }
    }

    function checkOTP() {
      const otp = ['otp1','otp2','otp3','otp4'].map(id => document.getElementById(id).value).join('');
      if (otp === '1234') {
        document.querySelectorAll('.otp-input').forEach(i => { i.style.borderColor = '#10B981'; i.style.background = '#F0FDF4'; });
      }
    }

    function startTimer() {
      let secs = 60;
      const timerEl = document.getElementById('timer');
      clearInterval(timerInterval);
      timerInterval = setInterval(() => {
        secs--;
        timerEl.textContent = ' (' + secs + ' ثانية)';
        if (secs <= 0) { clearInterval(timerInterval); timerEl.textContent = ''; }
      }, 1000);
    }

    function resendOTP() {
      showToast('📱 تم إرسال رمز التحقق مرة أخرى');
      startTimer();
    }

    function submitRegister() {
      const otp = ['otp1','otp2','otp3','otp4'].map(id => document.getElementById(id).value).join('');
      if (otp !== '1234') {
        alert('❌ رمز التحقق غير صحيح. جرّب: 1234');
        return;
      }
      const name = document.getElementById('fullName').value;
      const email = document.getElementById('email').value;
      const phone = document.getElementById('phone').value;
      localStorage.setItem('wslha_user', JSON.stringify({ name, email, phone, role: 'user', gender, balance: 0, joinDate: new Date().toLocaleDateString('ar-EG') }));
      showToast('🎉 تم إنشاء حسابك بنجاح! مرحباً بك في وصله!');
      setTimeout(() => window.location.href = '/home', 2000);
    }

    function showToast(msg) {
      const toast = document.getElementById('toast');
      toast.textContent = msg;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }
  </script>
</body>
</html>
