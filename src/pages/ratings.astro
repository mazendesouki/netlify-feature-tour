---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>التقييمات - وصله</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/wslha.css">
  <style>
    body { padding: 0; background: #F8FAFC; padding-bottom: 100px; }
    .ratings-header { background: linear-gradient(135deg, #1E3A8A 0%, #1D4ED8 100%); padding: 20px; }
    .header-nav { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
    .back-btn { color: white; font-size: 20px; text-decoration: none; }
    .header-title { color: white; font-size: 20px; font-weight: 800; }
    .page-content { padding: 20px; }
    .rating-overview { background: white; border-radius: 24px; padding: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); margin-bottom: 20px; }
    .overview-row { display: flex; align-items: center; gap: 24px; }
    .big-score { text-align: center; }
    .big-score-num { font-size: 64px; font-weight: 900; color: #1D4ED8; line-height: 1; }
    .big-score-stars { font-size: 24px; color: #F59E0B; margin: 6px 0; }
    .big-score-count { font-size: 13px; color: #94A3B8; font-weight: 600; }
    .bars-section { flex: 1; }
    .bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
    .bar-label { font-size: 13px; font-weight: 700; color: #64748B; width: 24px; text-align: center; }
    .bar-track { flex: 1; height: 8px; background: #F1F5F9; border-radius: 10px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 10px; transition: width 1s ease; }
    .bar-fill-5 { background: linear-gradient(90deg, #F59E0B, #FCD34D); }
    .bar-fill-4 { background: linear-gradient(90deg, #10B981, #34D399); }
    .bar-fill-3 { background: linear-gradient(90deg, #3B82F6, #60A5FA); }
    .bar-fill-2 { background: linear-gradient(90deg, #F97316, #FB923C); }
    .bar-fill-1 { background: linear-gradient(90deg, #EF4444, #F87171); }
    .bar-pct { font-size: 11px; color: #94A3B8; width: 30px; text-align: left; }
    .stats-summary { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 20px; }
    .sum-stat { background: white; border-radius: 16px; padding: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); text-align: center; }
    .sum-stat-num { font-size: 22px; font-weight: 900; color: #1D4ED8; }
    .sum-stat-label { font-size: 11px; color: #94A3B8; margin-top: 4px; font-weight: 600; }
    .rate-now-card { background: linear-gradient(135deg, #1E3A8A, #1D4ED8); border-radius: 20px; padding: 24px; color: white; margin-bottom: 20px; }
    .rate-driver-info { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
    .driver-av { width: 56px; height: 56px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 24px; border: 2px solid rgba(255,255,255,0.4); }
    .driver-rate-name { font-size: 17px; font-weight: 800; }
    .driver-rate-sub { font-size: 13px; opacity: 0.8; margin-top: 3px; }
    .stars-selector { display: flex; gap: 8px; justify-content: center; margin: 16px 0; }
    .star-btn { font-size: 36px; cursor: pointer; transition: transform 0.2s; filter: grayscale(1); opacity: 0.5; }
    .star-btn.active { filter: none; opacity: 1; transform: scale(1.2); }
    .star-btn:hover { transform: scale(1.3); filter: none; opacity: 1; }
    .rating-aspects { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
    .aspect-btn { border: 2px solid rgba(255,255,255,0.3); border-radius: 12px; padding: 10px; text-align: center; cursor: pointer; transition: all 0.3s; font-family: 'Cairo', sans-serif; font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.08); }
    .aspect-btn.selected { background: rgba(255,255,255,0.25); border-color: white; color: white; }
    .comment-input { width: 100%; padding: 12px; border: 2px solid rgba(255,255,255,0.3); border-radius: 12px; font-family: 'Cairo', sans-serif; font-size: 14px; background: rgba(255,255,255,0.1); color: white; outline: none; resize: none; direction: rtl; margin-bottom: 12px; }
    .comment-input::placeholder { color: rgba(255,255,255,0.5); }
    .submit-rating-btn { width: 100%; padding: 14px; background: white; color: #1D4ED8; border: none; border-radius: 14px; font-family: 'Cairo', sans-serif; font-size: 17px; font-weight: 800; cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
    .submit-rating-btn:hover { transform: translateY(-2px); }
    .review-card { background: white; border-radius: 18px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 14px; }
    .review-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .reviewer-av { width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, #1D4ED8, #3B82F6); display: flex; align-items: center; justify-content: center; font-size: 20px; color: white; font-weight: 800; flex-shrink: 0; }
    .reviewer-info { flex: 1; }
    .reviewer-name { font-size: 15px; font-weight: 800; color: #1E293B; }
    .reviewer-meta { font-size: 12px; color: #94A3B8; margin-top: 2px; }
    .review-stars { color: #F59E0B; font-size: 18px; }
    .review-text { font-size: 14px; color: #475569; line-height: 1.7; margin-bottom: 12px; }
    .review-tags { display: flex; gap: 8px; flex-wrap: wrap; }
    .review-tag { background: #F1F5F9; color: #64748B; padding: 4px 10px; border-radius: 8px; font-size: 11px; font-weight: 700; }
    .helpful-row { display: flex; align-items: center; gap: 10px; padding-top: 12px; border-top: 1px solid #F1F5F9; font-size: 13px; color: #94A3B8; }
    .helpful-btn { background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 8px; padding: 4px 12px; font-family: 'Cairo', sans-serif; font-size: 12px; font-weight: 700; cursor: pointer; transition: all 0.3s; }
    .helpful-btn:hover { background: #EFF6FF; color: #1D4ED8; border-color: #3B82F6; }
    .my-rating-card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 16px; border-right: 5px solid #F59E0B; }
    .my-rating-header { font-size: 15px; font-weight: 800; color: #1E293B; margin-bottom: 4px; }
    .my-rating-sub { font-size: 12px; color: #94A3B8; }
    .my-rating-stars { font-size: 22px; color: #F59E0B; margin: 10px 0; }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="ratings-header">
    <div class="header-nav">
      <a href="/home" class="back-btn">←</a>
      <div class="header-title">⭐ التقييمات</div>
    </div>
  </div>

  <div class="page-content">
    <!-- Rating Overview -->
    <div class="rating-overview">
      <div style="font-size:16px;font-weight:800;color:#1E293B;margin-bottom:16px">📊 تقييمك الإجمالي</div>
      <div class="overview-row">
        <div class="big-score">
          <div class="big-score-num">4.8</div>
          <div class="big-score-stars">⭐⭐⭐⭐⭐</div>
          <div class="big-score-count">من 24 تقييم</div>
        </div>
        <div class="bars-section">
          <div class="bar-row"><div class="bar-label">5⭐</div><div class="bar-track"><div class="bar-fill bar-fill-5" style="width:80%"></div></div><div class="bar-pct">80%</div></div>
          <div class="bar-row"><div class="bar-label">4⭐</div><div class="bar-track"><div class="bar-fill bar-fill-4" style="width:15%"></div></div><div class="bar-pct">15%</div></div>
          <div class="bar-row"><div class="bar-label">3⭐</div><div class="bar-track"><div class="bar-fill bar-fill-3" style="width:4%"></div></div><div class="bar-pct">4%</div></div>
          <div class="bar-row"><div class="bar-label">2⭐</div><div class="bar-track"><div class="bar-fill bar-fill-2" style="width:1%"></div></div><div class="bar-pct">1%</div></div>
          <div class="bar-row"><div class="bar-label">1⭐</div><div class="bar-track"><div class="bar-fill bar-fill-1" style="width:0%"></div></div><div class="bar-pct">0%</div></div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-summary">
      <div class="sum-stat">
        <div class="sum-stat-num">24</div>
        <div class="sum-stat-label">تقييم تلقيته</div>
      </div>
      <div class="sum-stat">
        <div class="sum-stat-num">18</div>
        <div class="sum-stat-label">تقييم قدّمته</div>
      </div>
      <div class="sum-stat">
        <div class="sum-stat-num">6</div>
        <div class="sum-stat-label">معلق التقييم</div>
      </div>
    </div>

    <!-- Rate Now -->
    <div class="rate-now-card">
      <div class="rate-driver-info">
        <div class="driver-av">م</div>
        <div>
          <div class="driver-rate-name">قيّم رحلتك الأخيرة</div>
          <div class="driver-rate-sub">🚗 محمد أحمد • مشوار المعادي • أمس</div>
        </div>
      </div>

      <div class="stars-selector" id="starsContainer">
        <span class="star-btn" onclick="setRating(1)">⭐</span>
        <span class="star-btn" onclick="setRating(2)">⭐</span>
        <span class="star-btn" onclick="setRating(3)">⭐</span>
        <span class="star-btn" onclick="setRating(4)">⭐</span>
        <span class="star-btn" onclick="setRating(5)">⭐</span>
      </div>

      <div id="ratingLabel" style="text-align:center;color:rgba(255,255,255,0.7);font-size:14px;margin-bottom:12px">اختر تقييمك</div>

      <div class="rating-aspects">
        <div class="aspect-btn" onclick="this.classList.toggle('selected')">😊 سلوك محترم</div>
        <div class="aspect-btn" onclick="this.classList.toggle('selected')">⚡ سريع</div>
        <div class="aspect-btn" onclick="this.classList.toggle('selected')">🚗 سيارة نظيفة</div>
        <div class="aspect-btn" onclick="this.classList.toggle('selected')">📍 التزم بالطريق</div>
        <div class="aspect-btn" onclick="this.classList.toggle('selected')">💰 سعر عادل</div>
        <div class="aspect-btn" onclick="this.classList.toggle('selected')">🎵 بيئة هادئة</div>
      </div>

      <textarea class="comment-input" rows="3" placeholder="شاركنا رأيك في التجربة... (اختياري)"></textarea>

      <button class="submit-rating-btn" onclick="submitRating()">⭐ إرسال التقييم</button>
    </div>

    <!-- My Ratings Given -->
    <div class="section-title">⭐ <span>تقييماتي للسائقين</span></div>

    <div class="my-rating-card">
      <div class="my-rating-header">✈️ رحلة مطار القاهرة</div>
      <div class="my-rating-sub">السائق: أحمد مصطفى • 20 مارس</div>
      <div class="my-rating-stars">⭐⭐⭐⭐⭐</div>
      <div style="font-size:13px;color:#475569">"سائق ممتاز، التزم بالوقت تماماً وساعدني في الحقائب"</div>
    </div>

    <div class="my-rating-card">
      <div class="my-rating-header">🏪 توصيل كارفور</div>
      <div class="my-rating-sub">السائق: محمد علي • 25 مارس</div>
      <div class="my-rating-stars" style="font-size:20px">⭐⭐⭐⭐</div>
      <div style="font-size:13px;color:#475569">"كويس جداً، بس وصل متأخر شوية"</div>
    </div>

    <!-- Reviews Received -->
    <div class="section-title" style="margin-top: 20px;">💬 <span>تقييمات السائقين لك</span></div>

    <div class="review-card">
      <div class="review-header">
        <div class="reviewer-av">م</div>
        <div class="reviewer-info">
          <div class="reviewer-name">محمد أحمد (سائق)</div>
          <div class="reviewer-meta">مشوار المعادي • منذ أسبوع</div>
        </div>
        <div class="review-stars">⭐⭐⭐⭐⭐</div>
      </div>
      <div class="review-text">"عميل ممتاز جداً، محترم وواضح في تحديد الموقع"</div>
      <div class="review-tags">
        <div class="review-tag">😊 محترم</div>
        <div class="review-tag">📍 موقع واضح</div>
        <div class="review-tag">⚡ سريع</div>
      </div>
    </div>

    <div class="review-card">
      <div class="review-header">
        <div class="reviewer-av" style="background:linear-gradient(135deg,#059669,#34D399)">أ</div>
        <div class="reviewer-info">
          <div class="reviewer-name">أحمد مصطفى (سائق)</div>
          <div class="reviewer-meta">توصيل مطار • منذ أسبوعين</div>
        </div>
        <div class="review-stars">⭐⭐⭐⭐⭐</div>
      </div>
      <div class="review-text">"عميل رائع، كان واضح في تحديد المطار والوقت، شكراً!"</div>
      <div class="review-tags">
        <div class="review-tag">✅ دقيق في المواعيد</div>
        <div class="review-tag">😊 محترم</div>
      </div>
    </div>

    <div class="review-card">
      <div class="review-header">
        <div class="reviewer-av" style="background:linear-gradient(135deg,#7C3AED,#A855F7)">س</div>
        <div class="reviewer-info">
          <div class="reviewer-name">سامي عبدالله (سائق)</div>
          <div class="reviewer-meta">مشوار وسط البلد • منذ 3 أسابيع</div>
        </div>
        <div class="review-stars">⭐⭐⭐⭐</div>
      </div>
      <div class="review-text">"عميل محترم، شكراً على التعامل الراقي"</div>
      <div class="review-tags">
        <div class="review-tag">😊 محترم</div>
      </div>
      <div class="helpful-row">
        هل كان هذا مفيداً؟
        <button class="helpful-btn" onclick="this.textContent='👍 نعم (3)'">👍 نعم (2)</button>
        <button class="helpful-btn">👎 لا</button>
      </div>
    </div>
  </div>

  <!-- Bottom Nav -->
  <nav class="bottom-nav">
    <a href="/home" class="nav-item">
      <span class="nav-icon">🏠</span>
      <span>الرئيسية</span>
    </a>
    <a href="/orders" class="nav-item">
      <span class="nav-icon">📋</span>
      <span>طلباتي</span>
    </a>
    <a href="/delivery" class="nav-center-btn">+</a>
    <a href="/wallet" class="nav-item">
      <span class="nav-icon">👛</span>
      <span>المحفظة</span>
    </a>
    <a href="/settings" class="nav-item">
      <span class="nav-icon">⚙️</span>
      <span>الإعدادات</span>
    </a>
  </nav>

  <script>
    let currentRating = 0;
    const labels = ['', '😟 سيء', '😐 مقبول', '😊 جيد', '😁 ممتاز', '🤩 رائع!'];

    function setRating(stars) {
      currentRating = stars;
      const starBtns = document.querySelectorAll('.star-btn');
      starBtns.forEach((btn, i) => {
        if (i < stars) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
      document.getElementById('ratingLabel').textContent = labels[stars];
    }

    function submitRating() {
      if (!currentRating) { alert('⚠️ يرجى اختيار عدد النجوم أولاً'); return; }
      alert('✅ شكراً على تقييمك!\n' + '⭐'.repeat(currentRating) + '\nتقييمك يساعدنا في تحسين خدماتنا');
      document.getElementById('starsContainer').innerHTML = '<div style="font-size:32px">⭐'.repeat(currentRating) + '</div>';
    }
  </script>
</body>
</html>
