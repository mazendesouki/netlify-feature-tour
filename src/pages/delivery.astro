---
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>توصيل الطلبات - وصله</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/wslha.css">
  <style>
    body { padding: 0; background: #F8FAFC; padding-bottom: 100px; }
    .delivery-header { background: linear-gradient(135deg, #1E3A8A 0%, #1D4ED8 100%); padding: 20px; }
    .header-nav { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
    .back-btn { color: white; font-size: 20px; text-decoration: none; }
    .header-title { color: white; font-size: 20px; font-weight: 800; }
    .header-icon { margin-right: auto; font-size: 22px; }
    .search-delivery { position: relative; }
    .search-delivery input { width: 100%; padding: 14px 20px 14px 50px; border: none; border-radius: 14px; font-family: 'Cairo', sans-serif; font-size: 15px; background: rgba(255,255,255,0.95); outline: none; }
    .search-delivery-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 20px; }
    .page-content { padding: 20px; }
    .features-banner { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 20px; }
    .features-scroll { display: flex; gap: 12px; overflow-x: auto; scrollbar-width: none; }
    .features-scroll::-webkit-scrollbar { display: none; }
    .feature-chip { display: flex; flex-direction: column; align-items: center; gap: 6px; background: #EFF6FF; border-radius: 14px; padding: 14px 16px; min-width: 90px; flex-shrink: 0; border: 2px solid transparent; transition: all 0.3s; cursor: pointer; }
    .feature-chip.active { background: #1D4ED8; border-color: #1D4ED8; }
    .feature-chip.active .chip-icon { color: white; }
    .feature-chip.active .chip-text { color: white; }
    .chip-icon { font-size: 26px; }
    .chip-text { font-size: 11px; font-weight: 700; color: #1D4ED8; }
    .categories-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 20px; }
    .cat-card { background: white; border-radius: 18px; padding: 18px 12px; text-align: center; box-shadow: 0 2px 12px rgba(0,0,0,0.06); cursor: pointer; transition: all 0.3s; border: 2px solid transparent; }
    .cat-card:hover { border-color: #3B82F6; transform: translateY(-3px); }
    .cat-icon { font-size: 32px; margin-bottom: 8px; display: block; }
    .cat-name { font-size: 12px; font-weight: 800; color: #1E293B; }
    .cat-count { font-size: 10px; color: #94A3B8; margin-top: 2px; }
    .store-card { background: white; border-radius: 18px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 16px; cursor: pointer; transition: all 0.3s; }
    .store-card:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
    .store-image { background: linear-gradient(135deg, #1E3A8A, #3B82F6); height: 130px; display: flex; align-items: center; justify-content: center; font-size: 60px; position: relative; }
    .store-badge { position: absolute; top: 12px; right: 12px; background: #10B981; color: white; padding: 4px 10px; border-radius: 10px; font-size: 11px; font-weight: 700; }
    .store-badge.closed { background: #94A3B8; }
    .store-info { padding: 16px; }
    .store-name { font-size: 17px; font-weight: 800; color: #1E293B; margin-bottom: 6px; }
    .store-meta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .store-meta-item { display: flex; align-items: center; gap: 4px; font-size: 12px; color: #64748B; font-weight: 600; }
    .store-tags { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
    .store-tag { background: #F1F5F9; color: #64748B; padding: 4px 10px; border-radius: 8px; font-size: 11px; font-weight: 700; }
    .delivery-order-panel { position: fixed; bottom: 0; left: 0; right: 0; background: white; border-radius: 24px 24px 0 0; padding: 20px; box-shadow: 0 -4px 20px rgba(0,0,0,0.1); z-index: 50; max-width: 480px; margin: 0 auto; }
    .panel-handle { width: 40px; height: 4px; background: #E2E8F0; border-radius: 4px; margin: 0 auto 16px; }
    .address-input { background: #F8FAFC; border-radius: 14px; padding: 14px; margin-bottom: 12px; border: 2px solid #E2E8F0; display: flex; align-items: center; gap: 12px; cursor: pointer; transition: all 0.3s; }
    .address-input:hover { border-color: #3B82F6; }
    .address-icon { font-size: 20px; }
    .address-text { flex: 1; font-size: 14px; color: #94A3B8; font-weight: 600; }
    .address-text.filled { color: #1E293B; }
    .price-est { display: flex; align-items: center; justify-content: space-between; background: #EFF6FF; border-radius: 12px; padding: 12px 16px; margin-bottom: 12px; }
    .price-est-label { font-size: 13px; color: #475569; font-weight: 600; }
    .price-est-value { font-size: 18px; font-weight: 900; color: #1D4ED8; }
    .order-btn { width: 100%; padding: 16px; background: linear-gradient(135deg, #1E3A8A, #1D4ED8); color: white; border: none; border-radius: 14px; font-family: 'Cairo', sans-serif; font-size: 17px; font-weight: 800; cursor: pointer; box-shadow: 0 4px 20px rgba(29,78,216,0.35); transition: all 0.3s; }
    .order-btn:hover { transform: translateY(-2px); }
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 200; display: none; align-items: flex-end; backdrop-filter: blur(4px); }
    .modal-overlay.show { display: flex; }
    .modal-sheet { background: white; border-radius: 24px 24px 0 0; padding: 24px; width: 100%; max-width: 480px; margin: 0 auto; max-height: 80vh; overflow-y: auto; }
    .item-card { display: flex; align-items: center; gap: 12px; padding: 14px; background: #F8FAFC; border-radius: 14px; margin-bottom: 10px; }
    .item-icon { font-size: 28px; width: 50px; height: 50px; background: white; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .item-name { font-size: 14px; font-weight: 800; color: #1E293B; }
    .item-price { font-size: 13px; color: #1D4ED8; font-weight: 700; }
    .item-counter { display: flex; align-items: center; gap: 8px; margin-right: auto; }
    .counter-btn { width: 30px; height: 30px; border-radius: 8px; border: none; background: #1D4ED8; color: white; font-size: 16px; font-weight: 900; cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .counter-num { font-size: 16px; font-weight: 900; color: #1E293B; min-width: 20px; text-align: center; }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="delivery-header">
    <div class="header-nav">
      <a href="/home" class="back-btn">←</a>
      <div class="header-title">🏪 توصيل الطلبات</div>
      <div class="header-icon">🛒</div>
    </div>
    <div class="search-delivery">
      <input type="text" placeholder="🔍 ابحث عن متجر أو منتج...">
      <span class="search-delivery-icon">🔍</span>
    </div>
  </div>

  <div class="page-content">
    <!-- Features Chips -->
    <div class="features-banner">
      <div style="font-size:14px;font-weight:800;color:#1E293B;margin-bottom:12px">🌟 مميزات خدمة التوصيل</div>
      <div class="features-scroll">
        <div class="feature-chip active">
          <span class="chip-icon">⚡</span>
          <span class="chip-text">توصيل سريع</span>
        </div>
        <div class="feature-chip">
          <span class="chip-icon">🆓</span>
          <span class="chip-text">توصيل مجاني</span>
        </div>
        <div class="feature-chip">
          <span class="chip-icon">📍</span>
          <span class="chip-text">تتبع حي</span>
        </div>
        <div class="feature-chip">
          <span class="chip-icon">💳</span>
          <span class="chip-text">دفع متعدد</span>
        </div>
        <div class="feature-chip">
          <span class="chip-icon">🌙</span>
          <span class="chip-text">24/7</span>
        </div>
        <div class="feature-chip">
          <span class="chip-icon">🔄</span>
          <span class="chip-text">إرجاع مضمون</span>
        </div>
      </div>
    </div>

    <!-- Categories -->
    <div class="section-title">🗂️ <span>الفئات</span></div>
    <div class="categories-grid">
      <div class="cat-card" onclick="filterCategory('supermarket')">
        <span class="cat-icon">🛒</span>
        <div class="cat-name">سوبر ماركت</div>
        <div class="cat-count">24 متجر</div>
      </div>
      <div class="cat-card" onclick="filterCategory('pharmacy')">
        <span class="cat-icon">💊</span>
        <div class="cat-name">صيدلية</div>
        <div class="cat-count">18 متجر</div>
      </div>
      <div class="cat-card" onclick="filterCategory('restaurant')">
        <span class="cat-icon">🍕</span>
        <div class="cat-name">مطاعم</div>
        <div class="cat-count">45 متجر</div>
      </div>
      <div class="cat-card" onclick="filterCategory('electronics')">
        <span class="cat-icon">📱</span>
        <div class="cat-name">إلكترونيات</div>
        <div class="cat-count">12 متجر</div>
      </div>
      <div class="cat-card" onclick="filterCategory('bakery')">
        <span class="cat-icon">🥖</span>
        <div class="cat-name">مخبز</div>
        <div class="cat-count">8 متجر</div>
      </div>
      <div class="cat-card" onclick="filterCategory('flowers')">
        <span class="cat-icon">💐</span>
        <div class="cat-name">هدايا وزهور</div>
        <div class="cat-count">6 متجر</div>
      </div>
    </div>

    <!-- Stores -->
    <div class="section-title">🏪 <span>المتاجر المتاحة</span></div>

    <div class="store-card" onclick="openStore('كارفور الجيزة')">
      <div class="store-image" style="background: linear-gradient(135deg, #0EA5E9, #38BDF8);">
        🛒
        <div class="store-badge">مفتوح ✅</div>
      </div>
      <div class="store-info">
        <div class="store-name">كارفور - الجيزة</div>
        <div class="store-meta">
          <span class="store-meta-item">⭐ 4.8</span>
          <span class="store-meta-item">⏱️ 25-35 دقيقة</span>
          <span class="store-meta-item">🚚 مجاني</span>
        </div>
        <div class="store-tags">
          <span class="store-tag">سوبر ماركت</span>
          <span class="store-tag">خضروات</span>
          <span class="store-tag">طازج</span>
        </div>
      </div>
    </div>

    <div class="store-card" onclick="openStore('صيدلية 19011')">
      <div class="store-image" style="background: linear-gradient(135deg, #059669, #34D399);">
        💊
        <div class="store-badge">مفتوح ✅</div>
      </div>
      <div class="store-info">
        <div class="store-name">صيدلية 19011</div>
        <div class="store-meta">
          <span class="store-meta-item">⭐ 4.9</span>
          <span class="store-meta-item">⏱️ 20-30 دقيقة</span>
          <span class="store-meta-item">🚚 5 جنيه</span>
        </div>
        <div class="store-tags">
          <span class="store-tag">أدوية</span>
          <span class="store-tag">مستلزمات طبية</span>
        </div>
      </div>
    </div>

    <div class="store-card" onclick="openStore('بيتزا هت')">
      <div class="store-image" style="background: linear-gradient(135deg, #DC2626, #F87171);">
        🍕
        <div class="store-badge">مفتوح ✅</div>
      </div>
      <div class="store-info">
        <div class="store-name">بيتزا هت</div>
        <div class="store-meta">
          <span class="store-meta-item">⭐ 4.6</span>
          <span class="store-meta-item">⏱️ 30-45 دقيقة</span>
          <span class="store-meta-item">🚚 10 جنيه</span>
        </div>
        <div class="store-tags">
          <span class="store-tag">بيتزا</span>
          <span class="store-tag">وجبات سريعة</span>
        </div>
      </div>
    </div>

    <div class="store-card" onclick="openStore('متجر الإلكترونيات')">
      <div class="store-image" style="background: linear-gradient(135deg, #7C3AED, #A855F7);">
        📱
        <div class="store-badge closed">مغلق حالياً</div>
      </div>
      <div class="store-info">
        <div class="store-name">متجر الإلكترونيات</div>
        <div class="store-meta">
          <span class="store-meta-item">⭐ 4.7</span>
          <span class="store-meta-item">⏱️ 45-60 دقيقة</span>
          <span class="store-meta-item">🚚 15 جنيه</span>
        </div>
        <div class="store-tags">
          <span class="store-tag">موبايلات</span>
          <span class="store-tag">إكسسوارات</span>
        </div>
      </div>
    </div>

    <div class="store-card" onclick="openStore('مخبز الأمل')">
      <div class="store-image" style="background: linear-gradient(135deg, #D97706, #FCD34D);">
        🥖
        <div class="store-badge">مفتوح ✅</div>
      </div>
      <div class="store-info">
        <div class="store-name">مخبز الأمل</div>
        <div class="store-meta">
          <span class="store-meta-item">⭐ 4.9</span>
          <span class="store-meta-item">⏱️ 15-20 دقيقة</span>
          <span class="store-meta-item">🚚 مجاني</span>
        </div>
        <div class="store-tags">
          <span class="store-tag">عيش</span>
          <span class="store-tag">كيك</span>
          <span class="store-tag">حلويات</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Order Panel -->
  <div class="delivery-order-panel">
    <div class="panel-handle"></div>

    <div class="address-input" onclick="setAddress()">
      <span class="address-icon">📍</span>
      <span class="address-text" id="addressText">حدّد موقع التوصيل</span>
      <span style="font-size:18px;color:#94A3B8">→</span>
    </div>

    <div class="price-est">
      <span class="price-est-label">⏱️ التوصيل في ~30 دقيقة</span>
      <span class="price-est-value">من 0 جنيه</span>
    </div>

    <button class="order-btn" onclick="confirmOrder()">
      🛒 اطلب الآن
    </button>
  </div>

  <!-- Store Modal -->
  <div class="modal-overlay" id="storeModal" onclick="closeStore()">
    <div class="modal-sheet" onclick="event.stopPropagation()">
      <div class="modal-handle"></div>
      <div class="modal-title" id="storeName">اسم المتجر</div>

      <div style="display:flex;gap:12px;margin-bottom:20px">
        <div style="background:#F8FAFC;border-radius:12px;padding:10px 16px;font-size:13px;font-weight:700;color:#475569">⭐ 4.8</div>
        <div style="background:#F8FAFC;border-radius:12px;padding:10px 16px;font-size:13px;font-weight:700;color:#475569">⏱️ 30 دقيقة</div>
        <div style="background:#F8FAFC;border-radius:12px;padding:10px 16px;font-size:13px;font-weight:700;color:#475569">🚚 مجاني</div>
      </div>

      <div style="font-size:16px;font-weight:800;color:#1E293B;margin-bottom:12px">🛍️ الأصناف المتاحة</div>

      <div class="item-card">
        <div class="item-icon">🥛</div>
        <div><div class="item-name">لبن بلدي 1 لتر</div><div class="item-price">25 جنيه</div></div>
        <div class="item-counter">
          <button class="counter-btn" onclick="changeQty(this, -1)">-</button>
          <span class="counter-num">0</span>
          <button class="counter-btn" onclick="changeQty(this, 1)">+</button>
        </div>
      </div>

      <div class="item-card">
        <div class="item-icon">🍞</div>
        <div><div class="item-name">عيش توست كامل</div><div class="item-price">15 جنيه</div></div>
        <div class="item-counter">
          <button class="counter-btn" onclick="changeQty(this, -1)">-</button>
          <span class="counter-num">0</span>
          <button class="counter-btn" onclick="changeQty(this, 1)">+</button>
        </div>
      </div>

      <div class="item-card">
        <div class="item-icon">🧃</div>
        <div><div class="item-name">عصير برتقال طبيعي</div><div class="item-price">20 جنيه</div></div>
        <div class="item-counter">
          <button class="counter-btn" onclick="changeQty(this, -1)">-</button>
          <span class="counter-num">0</span>
          <button class="counter-btn" onclick="changeQty(this, 1)">+</button>
        </div>
      </div>

      <div class="item-card">
        <div class="item-icon">🧀</div>
        <div><div class="item-name">جبنة رومي 250 جم</div><div class="item-price">45 جنيه</div></div>
        <div class="item-counter">
          <button class="counter-btn" onclick="changeQty(this, -1)">-</button>
          <span class="counter-num">0</span>
          <button class="counter-btn" onclick="changeQty(this, 1)">+</button>
        </div>
      </div>

      <button onclick="addToCart(); closeStore();" style="width:100%;padding:16px;background:linear-gradient(135deg,#1E3A8A,#1D4ED8);color:white;border:none;border-radius:14px;font-family:'Cairo',sans-serif;font-size:17px;font-weight:800;cursor:pointer;margin-top:8px">
        🛒 أضف للسلة
      </button>
    </div>
  </div>

  <!-- Bottom Nav -->
  <nav class="bottom-nav">
    <a href="/home" class="nav-item">
      <span class="nav-icon">🏠</span>
      <span>الرئيسية</span>
    </a>
    <a href="/orders" class="nav-item">
      <span class="nav-icon">📋</span>
      <span>طلباتي</span>
    </a>
    <a href="/delivery" class="nav-center-btn">+</a>
    <a href="/wallet" class="nav-item">
      <span class="nav-icon">👛</span>
      <span>المحفظة</span>
    </a>
    <a href="/settings" class="nav-item">
      <span class="nav-icon">⚙️</span>
      <span>الإعدادات</span>
    </a>
  </nav>

  <script>
    function openStore(name) {
      document.getElementById('storeName').textContent = name;
      document.getElementById('storeModal').classList.add('show');
    }
    function closeStore() {
      document.getElementById('storeModal').classList.remove('show');
    }
    function changeQty(btn, delta) {
      const numEl = btn.parentElement.querySelector('.counter-num');
      let num = parseInt(numEl.textContent) + delta;
      if (num < 0) num = 0;
      numEl.textContent = num;
    }
    function addToCart() {
      alert('✅ تمت الإضافة إلى السلة!');
    }
    function setAddress() {
      const addresses = ['مدينة نصر، شارع عباس العقاد', 'المعادي، شارع 9', 'الزمالك، شارع 26 يوليو', 'المهندسين، شارع جامعة الدول'];
      const addr = addresses[Math.floor(Math.random() * addresses.length)];
      document.getElementById('addressText').textContent = '📍 ' + addr;
      document.getElementById('addressText').classList.add('filled');
    }
    function confirmOrder() {
      const addr = document.getElementById('addressText').textContent;
      if (addr === 'حدّد موقع التوصيل') { alert('⚠️ يرجى تحديد موقع التوصيل أولاً'); return; }
      if (confirm('تأكيد الطلب؟\nالموقع: ' + addr)) {
        alert('✅ تم استلام طلبك!\n🚚 سيصل خلال 25-35 دقيقة\nرقم الطلب: #' + Math.floor(Math.random() * 9000 + 1000));
        window.location.href = '/orders';
      }
    }
    function filterCategory(cat) {
      alert('🔍 عرض متاجر فئة: ' + cat);
    }
  </script>
</body>
</html>
