---
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>الرئيسية - وصله</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/wslha.css">
  <style>
    body { padding: 0; background: #F8FAFC; padding-bottom: 80px; }
    .home-header { background: linear-gradient(135deg, #1E3A8A 0%, #1D4ED8 60%, #3B82F6 100%); padding: 24px 20px 60px; position: relative; overflow: hidden; }
    .home-header::before { content: ''; position: absolute; top: -60px; left: -60px; width: 300px; height: 300px; border-radius: 50%; background: rgba(255,255,255,0.06); }
    .header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; position: relative; z-index: 1; }
    .user-greeting { color: white; }
    .greeting-sub { font-size: 13px; opacity: 0.8; }
    .greeting-name { font-size: 22px; font-weight: 900; margin-top: 2px; }
    .header-icons { display: flex; gap: 12px; }
    .icon-btn { width: 42px; height: 42px; background: rgba(255,255,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: pointer; text-decoration: none; border: none; color: white; position: relative; transition: all 0.3s; }
    .icon-btn:hover { background: rgba(255,255,255,0.25); }
    .notif-dot { width: 8px; height: 8px; background: #EF4444; border-radius: 50%; position: absolute; top: 8px; right: 8px; border: 2px solid transparent; }
    .search-box { position: relative; z-index: 1; }
    .search-input { width: 100%; padding: 14px 20px 14px 50px; border: none; border-radius: 16px; font-family: 'Cairo', sans-serif; font-size: 15px; background: rgba(255,255,255,0.95); outline: none; direction: rtl; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
    .search-icon-btn { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 20px; background: none; border: none; cursor: pointer; }
    .balance-chip { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); padding: 8px 16px; border-radius: 20px; color: white; font-size: 14px; font-weight: 700; margin-bottom: 16px; backdrop-filter: blur(10px); text-decoration: none; position: relative; z-index: 1; }
    .services-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; padding: 0 20px; margin-top: -30px; position: relative; z-index: 5; }
    .service-tile { background: white; border-radius: 20px; padding: 20px 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); cursor: pointer; text-decoration: none; display: block; transition: all 0.3s; border: 2px solid transparent; }
    .service-tile:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0,0,0,0.12); border-color: #3B82F6; }
    .tile-icon { font-size: 36px; margin-bottom: 10px; display: block; }
    .tile-name { font-size: 15px; font-weight: 800; color: #1E293B; }
    .tile-sub { font-size: 11px; color: #94A3B8; margin-top: 4px; }
    .tile-badge { display: inline-block; background: #EFF6FF; color: #1D4ED8; padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: 700; margin-top: 8px; }
    .section-container { padding: 20px; }
    .section-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .section-title-text { font-size: 18px; font-weight: 800; color: #1E293B; }
    .see-all-link { font-size: 13px; font-weight: 700; color: #1D4ED8; text-decoration: none; }
    .promo-banner { background: linear-gradient(135deg, #1E3A8A 0%, #1D4ED8 100%); border-radius: 20px; padding: 20px; color: white; display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; overflow: hidden; position: relative; }
    .promo-banner::before { content: ''; position: absolute; top: -30px; left: -30px; width: 120px; height: 120px; border-radius: 50%; background: rgba(255,255,255,0.08); }
    .promo-text { font-size: 18px; font-weight: 900; margin-bottom: 4px; }
    .promo-sub { font-size: 12px; opacity: 0.85; }
    .promo-icon { font-size: 48px; opacity: 0.9; }
    .promo-code { background: rgba(255,255,255,0.2); border: 1px dashed rgba(255,255,255,0.5); padding: 6px 14px; border-radius: 8px; font-size: 16px; font-weight: 900; margin-top: 10px; display: inline-block; letter-spacing: 2px; }
    .promos-scroll { display: flex; gap: 14px; overflow-x: auto; scrollbar-width: none; }
    .promos-scroll::-webkit-scrollbar { display: none; }
    .promo-card { min-width: 220px; border-radius: 18px; padding: 18px; color: white; flex-shrink: 0; position: relative; overflow: hidden; }
    .promo-1 { background: linear-gradient(135deg, #7C3AED, #A855F7); }
    .promo-2 { background: linear-gradient(135deg, #DC2626, #F87171); }
    .promo-3 { background: linear-gradient(135deg, #D97706, #FCD34D); }
    .order-mini-card { background: white; border-radius: 16px; padding: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 12px; display: flex; align-items: center; gap: 14px; border-right: 4px solid #1D4ED8; cursor: pointer; text-decoration: none; }
    .order-mini-card.success { border-color: #10B981; }
    .order-mini-card.pending { border-color: #F59E0B; }
    .order-mini-icon { width: 48px; height: 48px; border-radius: 14px; background: #EFF6FF; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
    .order-mini-info { flex: 1; }
    .order-mini-title { font-size: 14px; font-weight: 800; color: #1E293B; }
    .order-mini-sub { font-size: 12px; color: #94A3B8; margin-top: 2px; }
    .order-mini-price { font-size: 16px; font-weight: 900; color: #1D4ED8; }
    .quick-actions { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
    .quick-action { background: white; border-radius: 16px; padding: 14px 8px; text-align: center; box-shadow: 0 2px 12px rgba(0,0,0,0.06); cursor: pointer; text-decoration: none; transition: all 0.3s; }
    .quick-action:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.1); }
    .qa-icon { font-size: 28px; margin-bottom: 6px; display: block; }
    .qa-text { font-size: 11px; font-weight: 700; color: #475569; }
    .rating-preview { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
    .rating-big-num { font-size: 56px; font-weight: 900; color: #1D4ED8; }
    .rating-stars-row { display: flex; gap: 4px; font-size: 22px; margin: 4px 0; }
    .rating-count { font-size: 13px; color: #94A3B8; }
    .rating-bars { flex: 1; }
    .rating-bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
    .rating-bar-label { font-size: 12px; font-weight: 700; color: #475569; width: 20px; text-align: center; }
    .rating-bar-track { flex: 1; height: 6px; background: #F1F5F9; border-radius: 10px; overflow: hidden; }
    .rating-bar-fill { height: 100%; background: linear-gradient(90deg, #1D4ED8, #60A5FA); border-radius: 10px; }
    .rating-bar-pct { font-size: 11px; color: #94A3B8; width: 30px; text-align: left; }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="home-header">
    <div class="header-top">
      <div class="user-greeting">
        <div class="greeting-sub">🌟 أهلاً وسهلاً،</div>
        <div class="greeting-name" id="userName">جاري التحميل...</div>
      </div>
      <div class="header-icons">
        <a href="/orders" class="icon-btn" title="الطلبات">📋</a>
        <button class="icon-btn" onclick="showNotifications()" style="position:relative;">
          🔔
          <span class="notif-dot"></span>
        </button>
        <a href="/settings" class="icon-btn" title="الإعدادات">⚙️</a>
      </div>
    </div>

    <a href="/wallet" class="balance-chip">
      👛 رصيد محفظتك: <strong id="userBalance">0</strong> جنيه
    </a>

    <div class="search-box">
      <input type="text" class="search-input" placeholder="🔍 ابحث عن خدمة أو موقع...">
      <button class="search-icon-btn">🗺️</button>
    </div>
  </div>

  <!-- Services Grid -->
  <div class="services-grid">
    <a href="/delivery" class="service-tile">
      <span class="tile-icon">🏪</span>
      <div class="tile-name">توصيل طلبات</div>
      <div class="tile-sub">المتاجر المحلية</div>
      <div class="tile-badge">⚡ 30 دقيقة</div>
    </a>
    <a href="/rides" class="service-tile">
      <span class="tile-icon">🚗</span>
      <div class="tile-name">مشاوير</div>
      <div class="tile-sub">داخل وبين المحافظات</div>
      <div class="tile-badge">🗺️ 27 محافظة</div>
    </a>
    <a href="/airport" class="service-tile">
      <span class="tile-icon">✈️</span>
      <div class="tile-name">المطار</div>
      <div class="tile-sub">ذهاب وعودة</div>
      <div class="tile-badge">🛡️ مضمون</div>
    </a>
    <a href="/wallet" class="service-tile">
      <span class="tile-icon">👛</span>
      <div class="tile-name">محفظتي</div>
      <div class="tile-sub">شحن وسحب رصيد</div>
      <div class="tile-badge">💳 متعدد</div>
    </a>
  </div>

  <!-- Quick Actions -->
  <div class="section-container">
    <div class="quick-actions">
      <a href="/orders" class="quick-action">
        <span class="qa-icon">📋</span>
        <div class="qa-text">طلباتي</div>
      </a>
      <a href="/ratings" class="quick-action">
        <span class="qa-icon">⭐</span>
        <div class="qa-text">التقييمات</div>
      </a>
      <a href="/wallet" class="quick-action">
        <span class="qa-icon">💰</span>
        <div class="qa-text">شحن رصيد</div>
      </a>
      <a href="/settings" class="quick-action">
        <span class="qa-icon">⚙️</span>
        <div class="qa-text">الإعدادات</div>
      </a>
    </div>

    <!-- Promo Banners -->
    <div class="section-row">
      <div class="section-title-text">🎁 عروض حصرية</div>
    </div>

    <div class="promos-scroll">
      <div class="promo-card promo-1">
        <div style="font-size:13px;opacity:0.9;margin-bottom:4px">خصم أول طلب</div>
        <div style="font-size:22px;font-weight:900">30% خصم</div>
        <div style="font-size:11px;opacity:0.8;margin-top:4px">على أول طلب توصيل</div>
        <div class="promo-code">WSLHA30</div>
      </div>
      <div class="promo-card promo-2">
        <div style="font-size:13px;opacity:0.9;margin-bottom:4px">مشوار مجاني</div>
        <div style="font-size:22px;font-weight:900">رحلة مجانية 🎉</div>
        <div style="font-size:11px;opacity:0.8;margin-top:4px">لكل مستخدم جديد</div>
        <div class="promo-code">FREE1</div>
      </div>
      <div class="promo-card promo-3">
        <div style="font-size:13px;opacity:0.9;margin-bottom:4px;color:#1E293B">توصيل المطار</div>
        <div style="font-size:22px;font-weight:900;color:#1E293B">20% خصم</div>
        <div style="font-size:11px;opacity:0.8;margin-top:4px;color:#1E293B">على رحلات المطار</div>
        <div class="promo-code" style="color:#1E293B;border-color:#1E293B">AIR20</div>
      </div>
    </div>

    <!-- Recent Orders -->
    <div class="section-row" style="margin-top: 20px;">
      <div class="section-title-text">📋 آخر الطلبات</div>
      <a href="/orders" class="see-all-link">عرض الكل</a>
    </div>

    <a href="/orders" class="order-mini-card success">
      <div class="order-mini-icon">🏪</div>
      <div class="order-mini-info">
        <div class="order-mini-title">طلب من سوبر ماركت</div>
        <div class="order-mini-sub">✅ تم التوصيل • منذ ساعتين</div>
      </div>
      <div class="order-mini-price">45 جنيه</div>
    </a>

    <a href="/orders" class="order-mini-card">
      <div class="order-mini-icon">🚗</div>
      <div class="order-mini-info">
        <div class="order-mini-title">مشوار - وسط البلد</div>
        <div class="order-mini-sub">✅ مكتمل • أمس</div>
      </div>
      <div class="order-mini-price">80 جنيه</div>
    </a>

    <a href="/orders" class="order-mini-card pending">
      <div class="order-mini-icon">✈️</div>
      <div class="order-mini-info">
        <div class="order-mini-title">توصيل مطار القاهرة</div>
        <div class="order-mini-sub">⏳ قيد التنفيذ</div>
      </div>
      <div class="order-mini-price">150 جنيه</div>
    </a>

    <!-- Ratings Summary -->
    <div class="section-row" style="margin-top: 20px;">
      <div class="section-title-text">⭐ تقييمك</div>
      <a href="/ratings" class="see-all-link">تفاصيل</a>
    </div>

    <div class="rating-preview">
      <div style="display:flex;gap:20px;align-items:center">
        <div style="text-align:center">
          <div class="rating-big-num">4.8</div>
          <div class="rating-stars-row">⭐⭐⭐⭐⭐</div>
          <div class="rating-count">من 24 تقييم</div>
        </div>
        <div class="rating-bars">
          <div class="rating-bar-row"><div class="rating-bar-label">5⭐</div><div class="rating-bar-track"><div class="rating-bar-fill" style="width:80%"></div></div><div class="rating-bar-pct">80%</div></div>
          <div class="rating-bar-row"><div class="rating-bar-label">4⭐</div><div class="rating-bar-track"><div class="rating-bar-fill" style="width:15%"></div></div><div class="rating-bar-pct">15%</div></div>
          <div class="rating-bar-row"><div class="rating-bar-label">3⭐</div><div class="rating-bar-track"><div class="rating-bar-fill" style="width:4%"></div></div><div class="rating-bar-pct">4%</div></div>
          <div class="rating-bar-row"><div class="rating-bar-label">2⭐</div><div class="rating-bar-track"><div class="rating-bar-fill" style="width:1%"></div></div><div class="rating-bar-pct">1%</div></div>
          <div class="rating-bar-row"><div class="rating-bar-label">1⭐</div><div class="rating-bar-track"><div class="rating-bar-fill" style="width:0%"></div></div><div class="rating-bar-pct">0%</div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Navigation -->
  <nav class="bottom-nav">
    <a href="/home" class="nav-item active">
      <span class="nav-icon">🏠</span>
      <span>الرئيسية</span>
    </a>
    <a href="/orders" class="nav-item">
      <span class="nav-icon">📋</span>
      <span>طلباتي</span>
    </a>
    <a href="/delivery" class="nav-center-btn" title="طلب جديد">+</a>
    <a href="/wallet" class="nav-item">
      <span class="nav-icon">👛</span>
      <span>المحفظة</span>
    </a>
    <a href="/settings" class="nav-item">
      <span class="nav-icon">⚙️</span>
      <span>الإعدادات</span>
    </a>
  </nav>

  <!-- Notification Modal -->
  <div class="modal-overlay hidden" id="notifModal" onclick="hideNotifications()">
    <div class="modal-content" onclick="event.stopPropagation()">
      <div class="modal-handle"></div>
      <div class="modal-title">🔔 الإشعارات</div>
      <div style="display:flex;flex-direction:column;gap:12px">
        <div style="display:flex;gap:12px;padding:14px;background:#F0FDF4;border-radius:14px;border-right:3px solid #10B981">
          <span style="font-size:24px">✅</span>
          <div><div style="font-weight:700;font-size:14px">تم توصيل طلبك بنجاح</div><div style="font-size:12px;color:#94A3B8;margin-top:4px">طلب رقم #4521 • منذ ساعتين</div></div>
        </div>
        <div style="display:flex;gap:12px;padding:14px;background:#EFF6FF;border-radius:14px;border-right:3px solid #1D4ED8">
          <span style="font-size:24px">🎁</span>
          <div><div style="font-weight:700;font-size:14px">عرض خاص! خصم 30%</div><div style="font-size:12px;color:#94A3B8;margin-top:4px">استخدم كود WSLHA30 • ينتهي اليوم</div></div>
        </div>
        <div style="display:flex;gap:12px;padding:14px;background:#FFFBEB;border-radius:14px;border-right:3px solid #F59E0B">
          <span style="font-size:24px">⭐</span>
          <div><div style="font-weight:700;font-size:14px">قيّم رحلتك الأخيرة</div><div style="font-size:12px;color:#94A3B8;margin-top:4px">ساعد في تحسين الخدمة • أمس</div></div>
        </div>
        <div style="display:flex;gap:12px;padding:14px;background:#F8FAFC;border-radius:14px;border-right:3px solid #94A3B8">
          <span style="font-size:24px">🚗</span>
          <div><div style="font-weight:700;font-size:14px">سائقك في الطريق إليك</div><div style="font-size:12px;color:#94A3B8;margin-top:4px">يصل خلال 5 دقائق • قبل يومين</div></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Load user data
    const user = JSON.parse(localStorage.getItem('wslha_user') || '{}');
    if (!user.name) {
      window.location.href = '/login';
    } else {
      document.getElementById('userName').textContent = user.name;
      document.getElementById('userBalance').textContent = (user.balance || 250).toLocaleString('ar-EG');
    }

    function showNotifications() {
      document.getElementById('notifModal').classList.remove('hidden');
    }
    function hideNotifications() {
      document.getElementById('notifModal').classList.add('hidden');
    }
  </script>
</body>
</html>
