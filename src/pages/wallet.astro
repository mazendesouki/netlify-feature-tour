---
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>المحفظة - وصله</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/wslha.css">
  <style>
    body { padding: 0; background: #F8FAFC; padding-bottom: 100px; }
    .wallet-header { background: linear-gradient(135deg, #1E3A8A 0%, #1D4ED8 100%); padding: 20px; }
    .header-nav { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
    .back-btn { color: white; font-size: 20px; text-decoration: none; }
    .header-title { color: white; font-size: 20px; font-weight: 800; }
    .page-content { padding: 20px; }
    .wallet-main-card { background: linear-gradient(135deg, #1E3A8A 0%, #1D4ED8 60%, #3B82F6 100%); border-radius: 24px; padding: 28px; color: white; position: relative; overflow: hidden; margin-bottom: 20px; }
    .wallet-main-card::before { content: ''; position: absolute; top: -40px; right: -40px; width: 180px; height: 180px; border-radius: 50%; background: rgba(255,255,255,0.08); }
    .wallet-main-card::after { content: ''; position: absolute; bottom: -50px; left: -30px; width: 140px; height: 140px; border-radius: 50%; background: rgba(255,255,255,0.06); }
    .wallet-label { font-size: 13px; opacity: 0.8; margin-bottom: 8px; position: relative; z-index: 1; }
    .wallet-amount { font-size: 48px; font-weight: 900; position: relative; z-index: 1; margin-bottom: 4px; }
    .wallet-currency { font-size: 22px; opacity: 0.85; }
    .wallet-card-num { font-size: 13px; opacity: 0.7; letter-spacing: 3px; margin-top: 12px; position: relative; z-index: 1; }
    .wallet-card-actions { display: flex; gap: 10px; margin-top: 20px; position: relative; z-index: 1; }
    .wallet-action { flex: 1; background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.3); color: white; padding: 12px 8px; border-radius: 14px; font-family: 'Cairo', sans-serif; font-size: 12px; font-weight: 700; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 6px; transition: all 0.3s; backdrop-filter: blur(10px); }
    .wallet-action:hover { background: rgba(255,255,255,0.28); transform: translateY(-2px); }
    .action-icon { font-size: 22px; }
    .quick-amounts { display: flex; gap: 10px; margin-bottom: 20px; overflow-x: auto; scrollbar-width: none; }
    .quick-amounts::-webkit-scrollbar { display: none; }
    .amount-chip { background: white; border: 2px solid #E2E8F0; border-radius: 14px; padding: 12px 18px; font-family: 'Cairo', sans-serif; font-size: 15px; font-weight: 800; color: #1D4ED8; cursor: pointer; transition: all 0.3s; white-space: nowrap; flex-shrink: 0; }
    .amount-chip.selected, .amount-chip:hover { background: #1D4ED8; color: white; border-color: #1D4ED8; }
    .method-tabs { display: flex; gap: 8px; margin-bottom: 16px; }
    .method-tab { flex: 1; padding: 10px; border: 2px solid #E2E8F0; border-radius: 12px; background: white; font-family: 'Cairo', sans-serif; font-size: 12px; font-weight: 700; color: #64748B; cursor: pointer; transition: all 0.3s; text-align: center; }
    .method-tab.active { border-color: #1D4ED8; background: #EFF6FF; color: #1D4ED8; }
    .charge-card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 16px; }
    .charge-methods { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
    .charge-method { border: 2px solid #E2E8F0; border-radius: 14px; padding: 16px; cursor: pointer; transition: all 0.3s; text-align: center; }
    .charge-method.selected, .charge-method:hover { border-color: #1D4ED8; background: #EFF6FF; }
    .charge-method-icon { font-size: 28px; margin-bottom: 8px; display: block; }
    .charge-method-name { font-size: 13px; font-weight: 800; color: #1E293B; }
    .charge-method-sub { font-size: 10px; color: #94A3B8; margin-top: 3px; }
    .charge-btn { width: 100%; padding: 16px; background: linear-gradient(135deg, #1E3A8A, #1D4ED8); color: white; border: none; border-radius: 14px; font-family: 'Cairo', sans-serif; font-size: 17px; font-weight: 800; cursor: pointer; box-shadow: 0 4px 20px rgba(29,78,216,0.35); transition: all 0.3s; }
    .charge-btn:hover { transform: translateY(-2px); }
    .withdraw-btn { width: 100%; padding: 16px; background: linear-gradient(135deg, #065F46, #059669); color: white; border: none; border-radius: 14px; font-family: 'Cairo', sans-serif; font-size: 17px; font-weight: 800; cursor: pointer; box-shadow: 0 4px 20px rgba(5,150,105,0.35); transition: all 0.3s; }
    .tx-card { background: white; border-radius: 16px; padding: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 10px; display: flex; align-items: center; gap: 14px; }
    .tx-icon { width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
    .tx-icon-credit { background: #F0FDF4; }
    .tx-icon-debit { background: #FFF5F5; }
    .tx-icon-transfer { background: #EFF6FF; }
    .tx-info { flex: 1; }
    .tx-title { font-size: 14px; font-weight: 800; color: #1E293B; }
    .tx-date { font-size: 12px; color: #94A3B8; margin-top: 2px; }
    .tx-amount { font-size: 17px; font-weight: 900; }
    .tx-amount.credit { color: #10B981; }
    .tx-amount.debit { color: #EF4444; }
    .stats-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 20px; }
    .stat-box { background: white; border-radius: 16px; padding: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); text-align: center; }
    .stat-box-num { font-size: 20px; font-weight: 900; color: #1D4ED8; }
    .stat-box-label { font-size: 11px; color: #94A3B8; margin-top: 4px; font-weight: 600; }
    .transfer-card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 16px; }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="wallet-header">
    <div class="header-nav">
      <a href="/home" class="back-btn">←</a>
      <div class="header-title">👛 المحفظة الإلكترونية</div>
    </div>

    <!-- Wallet Card -->
    <div class="wallet-main-card">
      <div class="wallet-label">💰 رصيدك الحالي</div>
      <div class="wallet-amount">
        <span id="walletBalance">250</span>
        <span class="wallet-currency"> جنيه</span>
      </div>
      <div class="wallet-card-num">**** **** **** 4521</div>
      <div style="position:relative;z-index:1;margin-top:8px;font-size:12px;opacity:0.75">
        وصله للدفع الإلكتروني • <span id="walletUser">مستخدم</span>
      </div>

      <div class="wallet-card-actions">
        <button class="wallet-action" onclick="showSection('charge')">
          <span class="action-icon">⬆️</span>
          شحن رصيد
        </button>
        <button class="wallet-action" onclick="showSection('withdraw')">
          <span class="action-icon">⬇️</span>
          سحب رصيد
        </button>
        <button class="wallet-action" onclick="showSection('transfer')">
          <span class="action-icon">🔄</span>
          تحويل
        </button>
        <button class="wallet-action" onclick="showSection('transactions')">
          <span class="action-icon">📋</span>
          العمليات
        </button>
      </div>
    </div>
  </div>

  <div class="page-content">
    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-box">
        <div class="stat-box-num">1,250</div>
        <div class="stat-box-label">💰 إجمالي الشحن</div>
      </div>
      <div class="stat-box">
        <div class="stat-box-num">840</div>
        <div class="stat-box-label">💸 إجمالي الإنفاق</div>
      </div>
      <div class="stat-box">
        <div class="stat-box-num">160</div>
        <div class="stat-box-label">🔄 المحوّل</div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="method-tabs">
      <button class="method-tab active" onclick="showSection('charge'); setActiveTab(this)">⬆️ شحن</button>
      <button class="method-tab" onclick="showSection('withdraw'); setActiveTab(this)">⬇️ سحب</button>
      <button class="method-tab" onclick="showSection('transfer'); setActiveTab(this)">🔄 تحويل</button>
      <button class="method-tab" onclick="showSection('transactions'); setActiveTab(this)">📋 السجل</button>
    </div>

    <!-- Charge Section -->
    <div id="chargeSection">
      <div class="charge-card">
        <div class="section-title">⬆️ <span>شحن الرصيد</span></div>

        <div style="font-size:14px;font-weight:700;color:#475569;margin-bottom:12px">اختر المبلغ السريع</div>
        <div class="quick-amounts">
          <div class="amount-chip" onclick="selectAmount(this, 50)">50 جنيه</div>
          <div class="amount-chip selected" onclick="selectAmount(this, 100)">100 جنيه</div>
          <div class="amount-chip" onclick="selectAmount(this, 200)">200 جنيه</div>
          <div class="amount-chip" onclick="selectAmount(this, 500)">500 جنيه</div>
          <div class="amount-chip" onclick="selectAmount(this, 1000)">1000 جنيه</div>
        </div>

        <div class="form-group">
          <label class="form-label">أو أدخل مبلغاً مخصصاً</label>
          <input type="number" class="form-control" placeholder="الحد الأدنى 20 جنيه" id="chargeAmount" value="100">
        </div>

        <div style="font-size:14px;font-weight:700;color:#475569;margin-bottom:12px">اختر طريقة الدفع</div>
        <div class="charge-methods">
          <div class="charge-method selected" onclick="selectMethod(this)">
            <span class="charge-method-icon">💳</span>
            <div class="charge-method-name">فيزا / ماستر</div>
            <div class="charge-method-sub">دفع فوري</div>
          </div>
          <div class="charge-method" onclick="selectMethod(this)">
            <span class="charge-method-icon">📱</span>
            <div class="charge-method-name">فودافون كاش</div>
            <div class="charge-method-sub">01XXXXXXXXX</div>
          </div>
          <div class="charge-method" onclick="selectMethod(this)">
            <span class="charge-method-icon">🏦</span>
            <div class="charge-method-name">انستا باي</div>
            <div class="charge-method-sub">بنوك مصرية</div>
          </div>
          <div class="charge-method" onclick="selectMethod(this)">
            <span class="charge-method-icon">💵</span>
            <div class="charge-method-name">كاش</div>
            <div class="charge-method-sub">نقاط خدمة</div>
          </div>
        </div>

        <button class="charge-btn" onclick="chargeWallet()">⬆️ شحن 100 جنيه</button>
      </div>
    </div>

    <!-- Withdraw Section -->
    <div id="withdrawSection" style="display:none">
      <div class="charge-card">
        <div class="section-title">⬇️ <span>سحب الرصيد</span></div>

        <div class="form-group">
          <label class="form-label">💰 المبلغ المراد سحبه</label>
          <input type="number" class="form-control" placeholder="الحد الأدنى 50 جنيه" id="withdrawAmount">
        </div>

        <div style="font-size:14px;font-weight:700;color:#475569;margin-bottom:12px">إلى أين؟</div>
        <div class="charge-methods">
          <div class="charge-method selected" onclick="selectMethod(this)">
            <span class="charge-method-icon">🏦</span>
            <div class="charge-method-name">حساب بنكي</div>
            <div class="charge-method-sub">1-2 يوم عمل</div>
          </div>
          <div class="charge-method" onclick="selectMethod(this)">
            <span class="charge-method-icon">📱</span>
            <div class="charge-method-name">فودافون كاش</div>
            <div class="charge-method-sub">فوري</div>
          </div>
          <div class="charge-method" onclick="selectMethod(this)">
            <span class="charge-method-icon">📱</span>
            <div class="charge-method-name">اورنج كاش</div>
            <div class="charge-method-sub">فوري</div>
          </div>
          <div class="charge-method" onclick="selectMethod(this)">
            <span class="charge-method-icon">🏪</span>
            <div class="charge-method-name">فروع متاجر</div>
            <div class="charge-method-sub">بكود استلام</div>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">📱 رقم المحفظة / الحساب</label>
          <input type="text" class="form-control" placeholder="01XXXXXXXXX">
        </div>

        <button class="withdraw-btn" onclick="withdrawWallet()">⬇️ طلب السحب</button>

        <div style="background:#FFF5F5;border-radius:12px;padding:12px;margin-top:12px;font-size:13px;color:#EF4444;font-weight:600;line-height:1.6">
          ⚠️ الحد الأدنى للسحب 50 جنيه • الحد الأقصى 5000 جنيه/يوم
        </div>
      </div>
    </div>

    <!-- Transfer Section -->
    <div id="transferSection" style="display:none">
      <div class="transfer-card">
        <div class="section-title">🔄 <span>تحويل رصيد</span></div>

        <div class="form-group">
          <label class="form-label">📱 رقم هاتف المستلم</label>
          <input type="tel" class="form-control" placeholder="01XXXXXXXXX" id="transferPhone">
        </div>

        <div class="form-group">
          <label class="form-label">💰 مبلغ التحويل</label>
          <input type="number" class="form-control" placeholder="الحد الأدنى 10 جنيه" id="transferAmount">
        </div>

        <div class="form-group">
          <label class="form-label">📝 سبب التحويل (اختياري)</label>
          <input type="text" class="form-control" placeholder="مثلاً: مشاركة تكلفة رحلة">
        </div>

        <button class="charge-btn" onclick="transferMoney()">🔄 تحويل الآن</button>
      </div>
    </div>

    <!-- Transactions Section -->
    <div id="transactionsSection" style="display:none">
      <div class="section-title">📋 <span>سجل العمليات</span></div>

      <div class="tx-card">
        <div class="tx-icon tx-icon-credit">⬆️</div>
        <div class="tx-info">
          <div class="tx-title">شحن رصيد - فيزا</div>
          <div class="tx-date">اليوم، 10:30 ص</div>
        </div>
        <div class="tx-amount credit">+200 جنيه</div>
      </div>

      <div class="tx-card">
        <div class="tx-icon tx-icon-debit">🚗</div>
        <div class="tx-info">
          <div class="tx-title">مشوار - المعادي</div>
          <div class="tx-date">أمس، 3:15 م</div>
        </div>
        <div class="tx-amount debit">-80 جنيه</div>
      </div>

      <div class="tx-card">
        <div class="tx-icon tx-icon-debit">🏪</div>
        <div class="tx-info">
          <div class="tx-title">توصيل - كارفور</div>
          <div class="tx-date">25 مارس، 7:40 م</div>
        </div>
        <div class="tx-amount debit">-45 جنيه</div>
      </div>

      <div class="tx-card">
        <div class="tx-icon tx-icon-credit">⬆️</div>
        <div class="tx-info">
          <div class="tx-title">شحن رصيد - فودافون كاش</div>
          <div class="tx-date">20 مارس، 11:00 ص</div>
        </div>
        <div class="tx-amount credit">+500 جنيه</div>
      </div>

      <div class="tx-card">
        <div class="tx-icon tx-icon-transfer">🔄</div>
        <div class="tx-info">
          <div class="tx-title">تحويل لـ 01XXXXXXXX</div>
          <div class="tx-date">18 مارس، 2:00 م</div>
        </div>
        <div class="tx-amount debit">-100 جنيه</div>
      </div>

      <div class="tx-card">
        <div class="tx-icon tx-icon-credit">✈️</div>
        <div class="tx-info">
          <div class="tx-title">استرداد - رحلة مطار</div>
          <div class="tx-date">15 مارس، 9:20 ص</div>
        </div>
        <div class="tx-amount credit">+150 جنيه</div>
      </div>

      <div class="tx-card">
        <div class="tx-icon tx-icon-debit">⬇️</div>
        <div class="tx-info">
          <div class="tx-title">سحب - فودافون كاش</div>
          <div class="tx-date">10 مارس، 5:00 م</div>
        </div>
        <div class="tx-amount debit">-300 جنيه</div>
      </div>
    </div>
  </div>

  <!-- Bottom Nav -->
  <nav class="bottom-nav">
    <a href="/home" class="nav-item">
      <span class="nav-icon">🏠</span>
      <span>الرئيسية</span>
    </a>
    <a href="/orders" class="nav-item">
      <span class="nav-icon">📋</span>
      <span>طلباتي</span>
    </a>
    <a href="/delivery" class="nav-center-btn">+</a>
    <a href="/wallet" class="nav-item active">
      <span class="nav-icon">👛</span>
      <span>المحفظة</span>
    </a>
    <a href="/settings" class="nav-item">
      <span class="nav-icon">⚙️</span>
      <span>الإعدادات</span>
    </a>
  </nav>

  <script>
    const user = JSON.parse(localStorage.getItem('wslha_user') || '{}');
    let balance = user.balance || 250;
    document.getElementById('walletBalance').textContent = balance.toLocaleString('ar-EG');
    document.getElementById('walletUser').textContent = user.name || 'مستخدم';

    function showSection(section) {
      ['charge','withdraw','transfer','transactions'].forEach(s => {
        document.getElementById(s + 'Section').style.display = 'none';
      });
      document.getElementById(section + 'Section').style.display = 'block';
    }

    function setActiveTab(btn) {
      document.querySelectorAll('.method-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
    }

    function selectAmount(el, amt) {
      document.querySelectorAll('.amount-chip').forEach(c => c.classList.remove('selected'));
      el.classList.add('selected');
      document.getElementById('chargeAmount').value = amt;
      document.querySelector('.charge-btn').textContent = '⬆️ شحن ' + amt + ' جنيه';
    }

    function selectMethod(el) {
      el.parentElement.querySelectorAll('.charge-method').forEach(m => m.classList.remove('selected'));
      el.classList.add('selected');
    }

    function chargeWallet() {
      const amt = parseInt(document.getElementById('chargeAmount').value);
      if (!amt || amt < 20) { alert('⚠️ الحد الأدنى للشحن 20 جنيه'); return; }
      if (confirm('تأكيد شحن ' + amt + ' جنيه لمحفظتك؟')) {
        balance += amt;
        document.getElementById('walletBalance').textContent = balance.toLocaleString('ar-EG');
        user.balance = balance;
        localStorage.setItem('wslha_user', JSON.stringify(user));
        alert('✅ تم شحن ' + amt + ' جنيه بنجاح!\nرصيدك الجديد: ' + balance + ' جنيه');
      }
    }

    function withdrawWallet() {
      const amt = parseInt(document.getElementById('withdrawAmount').value);
      if (!amt || amt < 50) { alert('⚠️ الحد الأدنى للسحب 50 جنيه'); return; }
      if (amt > balance) { alert('❌ رصيدك غير كافٍ'); return; }
      if (confirm('تأكيد سحب ' + amt + ' جنيه؟')) {
        balance -= amt;
        document.getElementById('walletBalance').textContent = balance.toLocaleString('ar-EG');
        user.balance = balance;
        localStorage.setItem('wslha_user', JSON.stringify(user));
        alert('✅ تم طلب سحب ' + amt + ' جنيه بنجاح!\nسيتم التحويل خلال 1-2 يوم عمل');
      }
    }

    function transferMoney() {
      const phone = document.getElementById('transferPhone').value;
      const amt = parseInt(document.getElementById('transferAmount').value);
      if (!phone) { alert('⚠️ أدخل رقم هاتف المستلم'); return; }
      if (!amt || amt < 10) { alert('⚠️ الحد الأدنى للتحويل 10 جنيه'); return; }
      if (amt > balance) { alert('❌ رصيدك غير كافٍ'); return; }
      if (confirm('تأكيد تحويل ' + amt + ' جنيه للرقم ' + phone + '؟')) {
        balance -= amt;
        document.getElementById('walletBalance').textContent = balance.toLocaleString('ar-EG');
        user.balance = balance;
        localStorage.setItem('wslha_user', JSON.stringify(user));
        alert('✅ تم التحويل بنجاح!\nتم إرسال ' + amt + ' جنيه لـ ' + phone);
      }
    }
  </script>
</body>
</html>
